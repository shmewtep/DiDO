        <schema:codeRepository rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://github.com/shmewtep/dialogueOnt</schema:codeRepository>
        <rdfs:label>DIDO</rdfs:label>
        <owl:versionInfo>2026-02-25</owl:versionInfo>
    </owl:Ontology>
    


