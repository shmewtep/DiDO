    <!-- http://purl.org/powla/powla.owl#Nonterminal -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#Nonterminal">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000253"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000291"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#Terminal -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#Terminal"/>
    


    <!-- http://purl.org/twc/dido#Dialogue -->

    <owl:Class rdf:about="http://purl.org/twc/dido#Dialogue">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000028"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#Turn"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000028"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000132"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000097"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000485"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#ProperInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>dialogue</rdfs:label>
        <skos:definition>an interactive communication between two or more entities</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/twc/dido#DialogueAct -->

    <owl:Class rdf:about="http://purl.org/twc/dido#DialogueAct">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000614"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>dialogue act</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/twc/dido#DialogueActAnnotation -->

    <owl:Class rdf:about="http://purl.org/twc/dido#DialogueActAnnotation">
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Terminal"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000332"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#DialogueAct"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000291"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/twc/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>dialogue act annotation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/twc/dido#DialogueTranscript -->

    <owl:Class rdf:about="http://purl.org/twc/dido#DialogueTranscript">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000069"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000095"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000089"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000059"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/twc/dido#UtteranceText"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000332"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/twc/dido#Dialogue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dialogue transcript</rdfs:label>
        <skos:definition>A digital or physical information content entity that provides a structured textual record of a conversation</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/twc/dido#Interlocutor -->

    <owl:Class rdf:about="http://purl.org/twc/dido#Interlocutor">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000016"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000227"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000097"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000485"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000356"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/twc/dido#Dialogue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>interlocutor</rdfs:label>
        <skos:definition>One who takes part in a conversation or dialogue</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/twc/dido#Turn -->

    <owl:Class rdf:about="http://purl.org/twc/dido#Turn">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000068"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#Dialogue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000139"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000097"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000485"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#Interval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>turn</rdfs:label>
        <skos:definition>a unit of conversation in which a single interlocutor holds the floor, without interruption from another interlocutor or other external circumstance</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/twc/dido#Utterance -->

    <owl:Class rdf:about="http://purl.org/twc/dido#Utterance">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/twc/dido#hasAddressee"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#Interlocutor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#DialogueAct"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000068"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#Dialogue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000229"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#UtteranceText"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000139"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000097"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000485"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000292"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/twc/dido#DialogueActAnnotation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#Interval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>utterance</rdfs:label>
        <skos:definition>a single unit of speech in spoken language that serves some pragmatic function</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/twc/dido#UtteranceText -->

    <owl:Class rdf:about="http://purl.org/twc/dido#UtteranceText">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000078"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>utterance text</rdfs:label>
        <skos:definition>a textual entity representing the output of an utterance</skos:definition>
    </owl:Class>
    


