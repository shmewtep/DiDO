        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">truth value</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000269 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000269">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000268"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://semanticscience.org/resource/SIO_000270"/>
        <dc:identifier>SIO_000269</dc:identifier>
        <dcterms:description xml:lang="en">true is a truth value that indicates that it holds under all possible worlds.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">true</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000270 -->

