        <dc:identifier>SIO_000641</dc:identifier>
        <dcterms:description xml:lang="en">has basis is a relation between a realizable entity and the quality that forms the basis for it.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
