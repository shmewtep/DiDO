        <rdfs:label xml:lang="en">computational entity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000614 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000614">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000614</dc:identifier>
        <dcterms:description xml:lang="en">An attribute is a characteristic of some entity.</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">attribute</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000616 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000616">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000289"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000059"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000616</dc:identifier>
        <dcterms:description xml:lang="en">A collection is a set for which there exists at least one member, although any member need not to exist at any point in the collection&apos;s existence.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">collection</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000776 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000776">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
                <owl:allValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000776"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000776</dc:identifier>
        <dcterms:description xml:lang="en">An object is an entity that is wholly identifiable at any instant of time during which it exists.</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">object</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_001040 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_001040">
