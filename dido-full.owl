    <!-- http://purl.org/dido#Dialogue -->

    <owl:Class rdf:about="http://purl.org/dido#Dialogue">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000028"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/dido#Turn"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000028"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000132"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000097"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000485"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#ProperInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>dialogue</rdfs:label>
        <skos:altLabel>conversation</skos:altLabel>
        <skos:definition>an interactive communication between two or more entities</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/dido#DialogueAct -->

    <owl:Class rdf:about="http://purl.org/dido#DialogueAct">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000014"/>
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000017"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/dido#hasAddressee"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/dido#Interlocutor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000226"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>dialogue act</rdfs:label>
        <skos:altLabel>communicative function</skos:altLabel>
        <skos:altLabel>functional segment</skos:altLabel>
        <skos:altLabel>speech act</skos:altLabel>
        <skos:definition>the meaning of an utterance at the level of illocutionary force</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/dido#DialogueActAnnotation -->

    <owl:Class rdf:about="http://purl.org/dido#DialogueActAnnotation">
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Terminal"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000332"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/dido#DialogueAct"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000291"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>dialogue act annotation</rdfs:label>
        <skos:definition>a label representing some dialogue act dimension with respect to a particular specification</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/dido#DialogueTranscript -->

    <owl:Class rdf:about="http://purl.org/dido#DialogueTranscript">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000069"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000095"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000089"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000059"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/dido#UtteranceText"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000332"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/dido#Dialogue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dialogue transcript</rdfs:label>
        <skos:definition>A digital or physical information content entity that provides a structured textual record of a conversation</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/dido#DiscourseRelation -->

    <owl:Class rdf:about="http://purl.org/dido#DiscourseRelation">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000253"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000291"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>discourse relation</rdfs:label>
        <skos:definition>a rhetorical or semantic connection between two or more utterances</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/dido#DiscourseRelationAnnotation -->

    <owl:Class rdf:about="http://purl.org/dido#DiscourseRelationAnnotation">
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Terminal"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000332"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/dido#DiscourseRelation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>discourse relation annotation</rdfs:label>
        <skos:definition>a label or marker representing a specific discourse relation</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/dido#Interlocutor -->

    <owl:Class rdf:about="http://purl.org/dido#Interlocutor">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000016"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000227"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000097"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000485"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000356"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/dido#Dialogue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>interlocutor</rdfs:label>
        <skos:altLabel>dialogue participant</skos:altLabel>
        <skos:definition>One who takes part in a conversation or dialogue</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/dido#Turn -->

    <owl:Class rdf:about="http://purl.org/dido#Turn">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000068"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/dido#Dialogue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000139"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000097"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000485"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#Interval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>turn</rdfs:label>
        <skos:definition>a unit of conversation in which a single interlocutor holds the floor, without interruption from another interlocutor or other external circumstance</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/dido#Utterance -->

    <owl:Class rdf:about="http://purl.org/dido#Utterance">
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Nonterminal"/>
