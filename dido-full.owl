        <skos:prefLabel xml:lang="fr">minute</skos:prefLabel>
        <skos:prefLabel xml:lang="es">minuto</skos:prefLabel>
        <skos:prefLabel xml:lang="it">minuto</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">minuto</skos:prefLabel>
        <skos:prefLabel xml:lang="nl">minuut</skos:prefLabel>
        <skos:prefLabel xml:lang="ru">одна минута</skos:prefLabel>
        <skos:prefLabel xml:lang="ar">دقيقة واحدة</skos:prefLabel>
