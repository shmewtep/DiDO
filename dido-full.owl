            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000139"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000097"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000485"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#Interval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>utterance</rdfs:label>
        <skos:definition>a single unit of speech in spoken language that serves some pragmatic function</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/dido#UtteranceText -->

    <owl:Class rdf:about="http://purl.org/dido#UtteranceText">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000078"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>utterance text</rdfs:label>
        <skos:definition>a textual entity representing the output of an utterance</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#Corpus -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#Corpus">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Document"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#hasSuperDocument"/>
                        <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:maxCardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Document"/>
        <rdfs:comment xml:lang="en">OPTIONAL type
A Corpus is a Document without superDocument</rdfs:comment>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#Document -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#Document">
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#POWLAElement"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#POWLAElement"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#documentID"/>
                        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.org/powla/powla.owl#Layer"/>
        <owl:disjointWith rdf:resource="http://purl.org/powla/powla.owl#Node"/>
        <owl:disjointWith rdf:resource="http://purl.org/powla/powla.owl#Relation"/>
        <rdfs:comment xml:lang="en">OPTIONAL type
A document is a(n annotated piece of) primary data as defined by the respective use case. A document can aggregate other documents (e.g., the Bible consists of several books), we thus extend the notion of document to collections of documents.

powla:Document is roughly corresponding to SALT Graph and PAULA anno sets.</rdfs:comment>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#DocumentLayer -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#DocumentLayer">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Layer"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#hasDocument"/>
                        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Layer"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#hasDocument"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">OPTIONAL type
Layer within a document</rdfs:comment>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#DominanceRelation -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#DominanceRelation">
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Relation"/>
        <rdfs:comment xml:lang="en">DEPRECATED object property
Dominance relations are labeled (reified) relations with coverage inheritance, i.e., the target node covers all terminals of the source node(s). Dominance relations are typical for phrase structure syntax.

This property, originally motivated from PAULA,  is deprecated in POWLA, as dominance relations are sufficiently described by powla:Relation and powla:hasParent.</rdfs:comment>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <owl:versionInfo xml:lang="en">dominance relations aren&apos;t actually necessary, a Relation is a DominanceRelation if it coincides with a hasChild property</owl:versionInfo>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#Layer -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#Layer">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#MarkableLayer"/>
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#StructLayer"/>
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#TokenLayer"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#POWLAElement"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#POWLAElement"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#layerID"/>
                        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.org/powla/powla.owl#Node"/>
        <owl:disjointWith rdf:resource="http://purl.org/powla/powla.owl#Relation"/>
        <rdfs:comment xml:lang="en">OPTIONAL type
A layer describes a group of annotations, this may be either within a document or independently from a particular document</rdfs:comment>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#MarkableLayer -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#MarkableLayer">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Layer"/>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://purl.org/powla/powla.owl#StructLayer"/>
                    </owl:Class>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://purl.org/powla/powla.owl#TokenLayer"/>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Layer"/>
        <rdfs:comment xml:lang="en">OPTIONAL type
Markable layers are visualized in a special way. with the current modelling, the status of a layer as a markable layer can be inferred and does not need to be asserted.</rdfs:comment>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#Node -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#Node">
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#POWLAElement"/>
        <owl:disjointWith rdf:resource="http://purl.org/powla/powla.owl#Relation"/>
        <rdfs:comment xml:lang="en">RECOMMENDED type.
Nodes represent units of linguistic annotation (`markables&apos;). Typical nodes have a defined extension or a position in the annotated data.

However, nodes may also be empty or not determined in their position if the annotated category can apply to nodes with a defined extension or position. An example for a non-positionable node with zero extension is the annotation of implicit semantic roles.

El Salvador is now the only Latin American country which still has troops in [Iraq]_LOC. Nicaragua, Honduras and the Dominican Republic have withdrawn their troops [0]_LOC.

In terms of frame semantics, withdrawing toops requires a location element, marked by [0]_LOC, but this is not realized in the local sentence. We can, however, infer its existence from a frame inventory (and in this case, also connect it with a string in the preceding text -- this is not always the case). However, it is impossible to define its actual string position in the second sentence.

Yet, the element marked by [0]_LOC is a valid powla:Node because if a phrase like &quot;from Iraq&quot; would have occurred in the sentence, it would have been annotated with the same linguistic features as the empty element.

Note that rdf:type powla:Node is recommended, but not obligatory, as this can be RDFS-inferred from (the obligatory) powla:next.</rdfs:comment>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#Nonterminal -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#Nonterminal">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Node"/>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://purl.org/powla/powla.owl#Terminal"/>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Node"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#hasChild"/>
                        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Node"/>
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#hasChild"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000253"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000291"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.org/powla/powla.owl#Terminal"/>
        <rdfs:comment xml:lang="en">OPTIONAL type
A powla:Node which is not a powla:Terminal (see there), RDFS-inferrable from powla:hasParent.</rdfs:comment>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#POWLAElement -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#POWLAElement">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Document"/>
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Layer"/>
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Node"/>
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Relation"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
        <rdfs:comment xml:lang="en">ABSTRACT type for POWLA data structures, not to be directly applied to data.</rdfs:comment>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#PointingRelation -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#PointingRelation">
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Relation"/>
        <rdfs:comment xml:lang="en">DEPRECATED object relation
A pointing relation is a labeled (reified) relation without coverage inheritance, i.e., the (terminals covered by the) target nodes do not typically overlap with the (terminals covered by the) source nodes.

This property, motivated from PAULA, is deprecated in POWLA, as it is sufiiently described by a relation without accompanying powla:hasParent.</rdfs:comment>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <owl:versionInfo xml:lang="en">pointing relations aren&apos;t actually necessary, a relation is a pointing relation if it does not coincide with a hasChild property.</owl:versionInfo>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#Relation -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#Relation">
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#POWLAElement"/>
        <rdfs:comment xml:lang="en">RECOMMENDED type
A relation represents a labelled edge that holds between two powla nodes. POWLA employs a reified representation, where source and target are linked with the relation via powla:hasSource and powla:hasTarget (resp., powla:isSourceOf and powla:isTargetOf)</rdfs:comment>
        <owl:versionInfo xml:lang="en">corresponding to SALT Edge, POM Relation

Note: in SALT no edges between Terminals</owl:versionInfo>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#Root -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#Root">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Node"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#hasParent"/>
                        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:cardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Node"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Nonterminal"/>
                            <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Terminal"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">OPTIONAL type
A root node is a powla:Node which is not a subject of a powla:hasParent property.
A number of properties that organize linguistic annotations into documents and corpora are based on the notion of root nodes as this limits the number of necessary links between data points and data sets. powla:Root can be RDFS-inferred from these or inferred from the absence of powla:hasParent under a closed world assumption.</rdfs:comment>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#StructLayer -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#StructLayer">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Layer"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#rootOfDocument"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Nonterminal"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#hasChild"/>
                                        <owl:someValuesFrom rdf:resource="http://purl.org/powla/powla.owl#Nonterminal"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#DocumentLayer"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#rootOfDocument"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Nonterminal"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#hasChild"/>
                                <owl:someValuesFrom rdf:resource="http://purl.org/powla/powla.owl#Nonterminal"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.org/powla/powla.owl#TokenLayer"/>
        <rdfs:comment xml:lang="en">OPTIONAL type
Struct layers are visualized as directed acyclic graphs (i.e., generalized trees). with the current modelling, the status of a layer as a struct layer can be inferred and does not need to be asserted.</rdfs:comment>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#Terminal -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#Terminal">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Node"/>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://purl.org/powla/powla.owl#Nonterminal"/>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Node"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#hasChild"/>
                        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:cardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Node"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#endPosition"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#startPosition"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">OPTIONAL type
A terminal is a node which does not have a child node (cf. hasParent/hasChild). Can be used as a basis for text anchoring.

Also corresponds to the single `base segmentation&apos; in LAF, and the `(privileged) tokenization layer&apos; in PAULA 1.0, which is used for calculating and querying token distance in corpus information systems.
Where non-minimal segments are needed as `(privileged) tokenization layer&apos;, we recommend to use external vocabularies, e.g., explicit nif:Word and nif:nextWord annotations.

Optional, as it can be inferred from powla:hasParent under a closed world assumption.</rdfs:comment>
        <owl:versionInfo xml:lang="en">roughly corresponding to SALT Terminal, PAULA 1.0 Token and PAULA 1.1 Terminal</owl:versionInfo>
    </owl:Class>
    


    <!-- http://purl.org/powla/powla.owl#TokenLayer -->

    <owl:Class rdf:about="http://purl.org/powla/powla.owl#TokenLayer">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.org/powla/powla.owl#Layer"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.org/powla/powla.owl#rootOfDocument"/>
                        <owl:allValuesFrom rdf:resource="http://purl.org/powla/powla.owl#Terminal"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.org/powla/powla.owl#Layer"/>
        <rdfs:comment xml:lang="en">OPTIONAL type
Token layers consist of annotations of terminal nodes, only. This class is necessary for visualization only, under the closed world assumption, however, it can be inferred and does not need to be asserted.</rdfs:comment>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000000 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000000">
        <dc:identifier>SIO_000000</dc:identifier>
        <dcterms:description xml:lang="en">Every thing is an entity.</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">entity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000004 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000004">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000776"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000279"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000004"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000370"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000004</dc:identifier>
        <dcterms:description xml:lang="en">A material entity is a physical entity that is spatially extended, exists as a whole at any point in time and has mass.</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">material entity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000005 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000005">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000614"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000218"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://semanticscience.org/resource/SIO_000340"/>
        <dc:identifier>SIO_000005</dc:identifier>
        <dcterms:description xml:lang="en">A quality is an attribute that is intrinsically associated with its bearer (or its parts), but whose presence/absence and observed/measured value may vary.</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">quality</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000006 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000006">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
                <owl:allValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000006</dc:identifier>
        <dcterms:description xml:lang="en">A process is an entity that is identifiable only through the unfolding of time, has temporal parts, and unless otherwise specified/predicted, cannot be identified from any instant of time in which it exists.</dcterms:description>
        <sio:subset>core</sio:subset>
        <sio:subset>process+</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">process</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000014 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000014">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000112"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000638"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000014</dc:identifier>
        <dcterms:description xml:lang="en">A disposition is the tendency of a capability to be exhibited under certain conditions or in response to a certain stimulus (trigger).</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">disposition</rdfs:label>
        <skos:example xml:lang="en">solubility (to dissolve when put in fluid); fragility (disposition to break when dropped)</skos:example>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000015 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000015">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000776"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
                <owl:allValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000015"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000015</dc:identifier>
        <dcterms:description xml:lang="en">information content entity is an object that requires some background knowledge or procedure to correctly interpret.</dcterms:description>
        <sio:subset>core</sio:subset>
        <sio:subset>ice+</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">information content entity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000016 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000016">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000340"/>
        <dc:identifier>SIO_000016</dc:identifier>
        <dcterms:description xml:lang="en">A role is a realizable entity that describes behaviours, rights and obligations of an entity in some particular circumstance.</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">role</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000017 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000017">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000112"/>
        <dc:identifier>SIO_000017</dc:identifier>
        <dcterms:description xml:lang="en">A function is a capability that satisfies some agentive objective, or (evolutionary) optimization.</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">function</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000037 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000037">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000258"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000776"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000216"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000052"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000037</dc:identifier>
        <dcterms:alternative xml:lang="en">physical dimensional quantity</dcterms:alternative>
        <dcterms:description xml:lang="en">A spatial quantity is a quantity obtained from measuring the spatial extent of an entity </dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">spatial quantity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000052 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000052">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000257"/>
                    <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000258"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000070"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000215"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000052</dc:identifier>
        <dcterms:description xml:lang="en">A quantity is an informational entity that gives the magnitude of a property.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">quantity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000069 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000069">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000602"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000062"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000006"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000355"/>
                                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000337"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000069</dc:identifier>
        <dcterms:description xml:lang="en">A data item consists of information that has been collected/generated towards some purpose.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">data item</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000070 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000070">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000366"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000070</dc:identifier>
        <dcterms:description xml:lang="en">A measurement value is a quantitative description that reflects the magnitude of some attribute.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">measurement value</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000074 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000074">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000052"/>
        <dc:identifier>SIO_000074</dc:identifier>
        <dcterms:description xml:lang="en">A unit of measurement is a definite magnitude of a physical quantity, defined and adopted by convention and/or by law, that is used as a standard for measurement of the same physical quantity.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">unit of measurement</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000075 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000075">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000015"/>
        <dc:identifier>SIO_000075</dc:identifier>
        <dcterms:description xml:lang="en">A mathematical entity is an information content entity that are components of a mathematical system or can be defined in mathematical terms.</dcterms:description>
        <sio:subset>math+</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">mathematical entity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000078 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000078">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000078</dc:identifier>
        <dcterms:description xml:lang="en">A language entity implements some language specification for the visual interpretation and is part of some document.</dcterms:description>
        <sio:subset>nlp+</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">language entity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000089 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000089">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000069"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000059"/>
                        <owl:allValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000069"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000069"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000213"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000396"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000089</dc:identifier>
        <dcterms:alternative xml:lang="en">data set</dcterms:alternative>
        <dcterms:description xml:lang="en">A dataset is a data item that is a collection of data items.</dcterms:description>
        <sio:equivalentTo rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.w3.org/ns/dcat#Dataset</sio:equivalentTo>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">dataset</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000097 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000097">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000602"/>
        <dc:identifier>SIO_000097</dc:identifier>
        <dcterms:description xml:lang="en">A software entity is a computational entity that can be interpreted by or directly executed by a processing unit.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">software entity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000108 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000108">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000078"/>
        <dc:identifier>SIO_000108</dc:identifier>
        <dcterms:description xml:lang="en">A character is a language symbol used to construct words.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">character</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000112 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000112">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000340"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000063"/>
                        <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000641"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000005"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000112</dc:identifier>
        <dcterms:description xml:lang="en">A capability is a realizable entity whose basis lies in one or more parts or qualities and reflects possibility of an entity to behave in a specified way under certain conditions or in response to a certain stimulus (trigger).</dcterms:description>
        <sio:subset>capability+</sio:subset>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">capability</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000114 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000114">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000078"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000028"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_001040"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000273"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000108"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000114</dc:identifier>
        <dcterms:description xml:lang="en">A word is the smallest free form (an item that may be expressed in isolation with semantic or pragmatic content) in a language.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">word</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000115 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000115">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000179"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000672"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000115</dc:identifier>
        <dcterms:description xml:lang="en">An identifier is a label that specifically refers to (identifies) an entity (instance/type).</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000136 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000136">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000078"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000563"/>
                <owl:allValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000136</dc:identifier>
        <dcterms:description xml:lang="en">A description is language entity in which elements of a language (formal or natural) are used to characterize an entity.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">description</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000179 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000179">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000275"/>
        <dc:identifier>SIO_000179</dc:identifier>
        <dcterms:description xml:lang="en">a label is a term that is associated with some entity</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">label</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000256 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000256">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000136"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000217"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000268"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000332"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000256</dc:identifier>
        <dcterms:description xml:lang="en">A proposition is a sentence expressing something true or false.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">proposition</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000257 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000257">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000052"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:complementOf>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000221"/>
                        <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000074"/>
                    </owl:Restriction>
                </owl:complementOf>
            </owl:Class>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://semanticscience.org/resource/SIO_000258"/>
        <dc:identifier>SIO_000257</dc:identifier>
        <dcterms:description xml:lang="en">A dimensionless quantity is a quantity that has no associated unit.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">dimensionless quantity</rdfs:label>
