     xmlns:schema1="http://schema.org/">
    <owl:Ontology rdf:about="https://purl.org/dido/dido-full.ttl">
        <owl:versionIRI rdf:resource="https://purl.org/dido/releases/2026-05-08/dido-full.ttl"/>
        <dc:creator xml:lang="en">Kelsey Rook</dc:creator>
        <dcterms:description>The Dialogue and Discourse Ontology (DIDO) supports the modeling of dialogue and dialogue data.</dcterms:description>
        <dcterms:license rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://opensource.org/license/mit</dcterms:license>
        <dcterms:modified>2026-2-4</dcterms:modified>
        <dcterms:title>Dialogue and Discourse Ontology (DiDO)</dcterms:title>
        <vann:preferredNamespacePrefix>dido</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://purl.org/dido#</vann:preferredNamespaceUri>
        <schema1:codeRepository rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://github.com/shmewtep/dialogueOnt</schema1:codeRepository>
        <rdfs:label>DIDO</rdfs:label>
        <owl:versionInfo>2026-05-08</owl:versionInfo>
    </owl:Ontology>
    


