    <!-- http://purl.org/twc/dido#Dialogue -->

    <owl:Class rdf:about="http://purl.org/twc/dido#Dialogue">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000028"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/twc/dido#Utterance"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000132"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000097"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000485"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#ProperInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>dialogue</rdfs:label>
        <skos:definition>an interactive communication between two or more entities</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/twc/dido#DialogueTranscript -->

    <owl:Class rdf:about="http://purl.org/twc/dido#DialogueTranscript">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000069"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000095"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000089"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000059"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/twc/dido#UtteranceText"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000332"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/twc/dido#Dialogue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dialogue transcript</rdfs:label>
        <skos:definition>A digital or physical information content entity that provides a structured textual record of a conversation</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/twc/dido#Interlocutor -->

    <owl:Class rdf:about="http://purl.org/twc/dido#Interlocutor">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000016"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000227"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000097"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000485"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000356"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/twc/dido#Dialogue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>interlocutor</rdfs:label>
        <skos:definition>One who takes part in a conversation or dialogue</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/twc/dido#Utterance -->

    <owl:Class rdf:about="http://purl.org/twc/dido#Utterance">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000229"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/twc/dido#UtteranceText"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000068"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.org/twc/dido#Dialogue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000139"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000097"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000485"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:onClass>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.w3.org/2006/time#Interval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>utterance</rdfs:label>
        <skos:definition>a single unit of speech in spoken language that serves some pragmatic function</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/twc/dido#UtteranceText -->

    <owl:Class rdf:about="http://purl.org/twc/dido#UtteranceText">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000078"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label>utterance text</rdfs:label>
        <skos:definition>a textual entity representing the output of an utterance</skos:definition>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000000 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000000">
        <dc:identifier>SIO_000000</dc:identifier>
        <dcterms:description xml:lang="en">Every thing is an entity.</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">entity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000004 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000004">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000776"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000008"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000279"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000004"/>
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000370"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000004</dc:identifier>
        <dcterms:description xml:lang="en">A material entity is a physical entity that is spatially extended, exists as a whole at any point in time and has mass.</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">material entity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000005 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000005">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000614"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000218"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://semanticscience.org/resource/SIO_000340"/>
        <dc:identifier>SIO_000005</dc:identifier>
        <dcterms:description xml:lang="en">A quality is an attribute that is intrinsically associated with its bearer (or its parts), but whose presence/absence and observed/measured value may vary.</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">quality</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000006 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000006">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
                <owl:allValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000006"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000006</dc:identifier>
        <dcterms:description xml:lang="en">A process is an entity that is identifiable only through the unfolding of time, has temporal parts, and unless otherwise specified/predicted, cannot be identified from any instant of time in which it exists.</dcterms:description>
        <sio:subset>core</sio:subset>
        <sio:subset>process+</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">process</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000015 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000015">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000776"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000053"/>
                <owl:allValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000015"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000015</dc:identifier>
        <dcterms:description xml:lang="en">information content entity is an object that requires some background knowledge or procedure to correctly interpret.</dcterms:description>
        <sio:subset>core</sio:subset>
        <sio:subset>ice+</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">information content entity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000016 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000016">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000340"/>
        <dc:identifier>SIO_000016</dc:identifier>
        <dcterms:description xml:lang="en">A role is a realizable entity that describes behaviours, rights and obligations of an entity in some particular circumstance.</dcterms:description>
        <sio:subset>core</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">role</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000037 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000037">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000258"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000776"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000216"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000052"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000037</dc:identifier>
        <dcterms:alternative xml:lang="en">physical dimensional quantity</dcterms:alternative>
        <dcterms:description xml:lang="en">A spatial quantity is a quantity obtained from measuring the spatial extent of an entity </dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">spatial quantity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000052 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000052">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000257"/>
                    <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000258"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000070"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000011"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000215"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000052</dc:identifier>
        <dcterms:description xml:lang="en">A quantity is an informational entity that gives the magnitude of a property.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">quantity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000069 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000069">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000602"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000062"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://semanticscience.org/resource/SIO_000006"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000355"/>
                                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/SIO_000337"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000069</dc:identifier>
        <dcterms:description xml:lang="en">A data item consists of information that has been collected/generated towards some purpose.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">data item</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000070 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000070">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000366"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000070</dc:identifier>
        <dcterms:description xml:lang="en">A measurement value is a quantitative description that reflects the magnitude of some attribute.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">measurement value</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000074 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000074">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000052"/>
        <dc:identifier>SIO_000074</dc:identifier>
        <dcterms:description xml:lang="en">A unit of measurement is a definite magnitude of a physical quantity, defined and adopted by convention and/or by law, that is used as a standard for measurement of the same physical quantity.</dcterms:description>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">unit of measurement</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000075 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000075">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000015"/>
        <dc:identifier>SIO_000075</dc:identifier>
        <dcterms:description xml:lang="en">A mathematical entity is an information content entity that are components of a mathematical system or can be defined in mathematical terms.</dcterms:description>
        <sio:subset>math+</sio:subset>
        <rdfs:isDefinedBy rdf:resource="http://semanticscience.org/ontology/sio.owl"/>
        <rdfs:label xml:lang="en">mathematical entity</rdfs:label>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/SIO_000078 -->

    <owl:Class rdf:about="http://semanticscience.org/resource/SIO_000078">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/SIO_000015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/SIO_000300"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dc:identifier>SIO_000078</dc:identifier>
