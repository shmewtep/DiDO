<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_50> a dido:UtteranceText ;
    sio:SIO_000300 "whatever comes to your mind"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_51> a dido:UtteranceText ;
    sio:SIO_000300 "no answer"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_52> a dido:UtteranceText ;
    sio:SIO_000300 "okay"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_53> a dido:UtteranceText ;
    sio:SIO_000300 " what do you do to relax"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_54> a dido:UtteranceText ;
    sio:SIO_000300 "i like reading books i enjoy i enjoy cooking"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_55> a dido:UtteranceText ;
    sio:SIO_000300 "um exercising is great"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_56> a dido:UtteranceText ;
    sio:SIO_000300 "awesome"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_57> a dido:UtteranceText ;
    sio:SIO_000300 "how are you at controlling your temper"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_58> a dido:UtteranceText ;
    sio:SIO_000300 "i'm i'm i'm pretty good at it"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_59> a dido:UtteranceText ;
    sio:SIO_000300 "um"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_6> a dido:UtteranceText ;
    sio:SIO_000300 "good"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_60> a dido:UtteranceText ;
    sio:SIO_000300 "really"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_61> a dido:UtteranceText ;
    sio:SIO_000300 "yeah"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_62> a dido:UtteranceText ;
    sio:SIO_000300 "when was the last time you argued with someone and what was it about"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_63> a dido:UtteranceText ;
    sio:SIO_000300 "um probably about"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_64> a dido:UtteranceText ;
    sio:SIO_000300 "two weeks ago"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_65> a dido:UtteranceText ;
    sio:SIO_000300 "how did you feel in that moment"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_66> a dido:UtteranceText ;
    sio:SIO_000300 "uh frustrated"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_67> a dido:UtteranceText ;
    sio:SIO_000300 "tell me more about that"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_68> a dido:UtteranceText ;
    sio:SIO_000300 "um"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_69> a dido:UtteranceText ;
    sio:SIO_000300 "i don't like bias"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_7> a dido:UtteranceText ;
    sio:SIO_000300 "that's good"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_70> a dido:UtteranceText ;
    sio:SIO_000300 "um i don't like um when someone says they're gonna do something and they don't"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_71> a dido:UtteranceText ;
    sio:SIO_000300 "mhm"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_72> a dido:UtteranceText ;
    sio:SIO_000300 "how close are you to them"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_73> a dido:UtteranceText ;
    sio:SIO_000300 "uh somewhat"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_74> a dido:UtteranceText ;
    sio:SIO_000300 "how do you know them"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_75> a dido:UtteranceText ;
    sio:SIO_000300 "friendship"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_76> a dido:UtteranceText ;
    sio:SIO_000300 "okay"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_77> a dido:UtteranceText ;
    sio:SIO_000300 "what are some things you like to do for fun"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_78> a dido:UtteranceText ;
    sio:SIO_000300 "i like to play sports i enjoy uh going out with friends and family"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_79> a dido:UtteranceText ;
    sio:SIO_000300 "playing games"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_8> a dido:UtteranceText ;
    sio:SIO_000300 "where are you from originally"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_80> a dido:UtteranceText ;
    sio:SIO_000300 "nice"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_81> a dido:UtteranceText ;
    sio:SIO_000300 "who's someone that's been a positive influence in your life"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_82> a dido:UtteranceText ;
    sio:SIO_000300 "grandparents"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_83> a dido:UtteranceText ;
    sio:SIO_000300 "parents"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_84> a dido:UtteranceText ;
    sio:SIO_000300 "aww"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_85> a dido:UtteranceText ;
    sio:SIO_000300 "can you tell me about that"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_86> a dido:UtteranceText ;
    sio:SIO_000300 "um yeah i mean they've always given me great advice"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_87> a dido:UtteranceText ;
    sio:SIO_000300 "they've always kept it real"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_88> a dido:UtteranceText ;
    sio:SIO_000300 "how close are you to your family"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_89> a dido:UtteranceText ;
    sio:SIO_000300 "real close"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_9> a dido:UtteranceText ;
    sio:SIO_000300 "atlanta georgia"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_90> a dido:UtteranceText ;
    sio:SIO_000300 "is there anything you regret"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_91> a dido:UtteranceText ;
    sio:SIO_000300 "i would say going to college right after high school"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_92> a dido:UtteranceText ;
    sio:SIO_000300 "why"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_93> a dido:UtteranceText ;
    sio:SIO_000300 "well i would've been done by now you know"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_94> a dido:UtteranceText ;
    sio:SIO_000300 "i would have been probably out in the field"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_95> a dido:UtteranceText ;
    sio:SIO_000300 "in the career field"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_96> a dido:UtteranceText ;
    sio:SIO_000300 "what made you decide to do that"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_97> a dido:UtteranceText ;
    sio:SIO_000300 "uh taking a job off the street"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_98> a dido:UtteranceText ;
    sio:SIO_000300 "could you have done anything to avoid it"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/utteranceText_300_99> a dido:UtteranceText ;
    sio:SIO_000300 "i'm sure i could've yes"^^xsd:string .

