###  http://semanticscience.org/resource/SIO_010000
sio:SIO_010000 rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:unionOf ( sio:SIO_010377
                                                   sio:SIO_010378
                                                 )
                                   ] ;
               rdfs:subClassOf sio:SIO_010046 ;
               dc:identifier "SIO_010000" ;
               dcterms:description "A biological organisn is a biological entity that consists of one or more cells and is capable of genomic replication (independently or not)."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "organism"@en .


###  http://semanticscience.org/resource/SIO_010001
sio:SIO_010001 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_010046 ;
               dc:identifier "SIO_010001" ;
               dcterms:description "A cell is a biological entity that is contained by a plasma membrane."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "cell"@en .


###  http://semanticscience.org/resource/SIO_010004
sio:SIO_010004 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_000004 ;
               dc:identifier "SIO_010004" ;
               dcterms:description "A chemical entity is a material entity that pertains to chemistry."@en ;
               sio:equivalentTo "CHEBI:23367" ;
               sio:subset "chemical+" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "chemical entity"@en ;
               skos:example "atom, ion, molecule, chemical substance,"@en .


###  http://semanticscience.org/resource/SIO_010046
sio:SIO_010046 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_010462 ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty sio:SIO_000068 ;
                                 owl:someValuesFrom sio:SIO_010000
                               ] ;
               dc:identifier "SIO_010046" ;
               dcterms:description "A biological entity is a heterogeneous substance that contains genomic material or is the product of a biological process."@en ;
               sio:subset "chemical-" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "biological entity"@en .


###  http://semanticscience.org/resource/SIO_010375
sio:SIO_010375 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_010377 ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty sio:SIO_000053 ;
                                 owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                 owl:onClass sio:SIO_010001
                               ] ;
               owl:disjointWith sio:SIO_010376 ;
               dc:identifier "SIO_010375" ;
               dcterms:description "A multi-cellular organism is an organism that consists of more than one cell."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "multicellular organism"@en .


###  http://semanticscience.org/resource/SIO_010376
sio:SIO_010376 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_010001 ,
                               sio:SIO_010377 ,
                               [ rdf:type owl:Class ;
                                 owl:complementOf [ rdf:type owl:Restriction ;
                                                    owl:onProperty sio:SIO_000093 ;
                                                    owl:someValuesFrom sio:SIO_010046
                                                  ]
                               ] ;
               dc:identifier "SIO_010376" ;
               dcterms:description "A unicellular organism is a organism that is composed of a single cell."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "unicellular organism"@en .


###  http://semanticscience.org/resource/SIO_010377
sio:SIO_010377 rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:unionOf ( sio:SIO_010375
                                                   sio:SIO_010376
                                                 )
                                   ] ;
               rdfs:subClassOf sio:SIO_010000 ;
               owl:disjointWith sio:SIO_010378 ;
               dc:identifier "SIO_010377" ;
               dcterms:description "A cellular organism is an organism that contains one or more cells."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "cellular organism"@en .


###  http://semanticscience.org/resource/SIO_010378
sio:SIO_010378 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_010000 ;
               dc:identifier "SIO_010378" ;
               dcterms:description "A non-cellular organism is an organism that does not contain a cell."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "non-cellular organism"@en .


###  http://semanticscience.org/resource/SIO_010410
sio:SIO_010410 rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( sio:SIO_000004
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty sio:SIO_000644 ;
                                                            owl:someValuesFrom sio:SIO_000340
                                                          ]
                                                        ) ;
