               rdfs:subPropertyOf sio:SIO_000132 ;
               owl:inverseOf sio:SIO_000232 ;
               dc:identifier "SIO_000229" ;
               dcterms:description "has output is a relation between an process and an entity, where the entity is present at the end of the process."@en ;
               sio:subset "core" ,
                          "sadi"@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has output"@en .


###  http://semanticscience.org/resource/SIO_000232
sio:SIO_000232 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000062 ;
               dc:identifier "SIO_000232" ;
               dcterms:description "is output of is a relation between an entity and a process, where the entity is present at the end of the process."@en ;
               sio:subset "sadi"@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is output of"@en ;
               skos:example "glucose-6-phosphate and ADP are outputs in the hexokinase-mediated conversion of glucose to glucose-6-phosphate."@en .


###  http://semanticscience.org/resource/SIO_000273
sio:SIO_000273 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000053 ;
               owl:inverseOf sio:SIO_000310 ;
               dc:identifier "SIO_000273" ;
               dcterms:description "has direct part is a relation to specify a part at a particular level of granularity"@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has direct part"@en ;
               skos:example "a car has an engine as a direct part"@en .


###  http://semanticscience.org/resource/SIO_000310
sio:SIO_000310 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000093 ;
               dc:identifier "SIO_000310" ;
               dcterms:description "is direct part of is a relation between a specific part (at some level of granularity) and its whole."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is direct part of"@en .


###  http://semanticscience.org/resource/SIO_000322
sio:SIO_000322 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000001 ;
               rdf:type owl:SymmetricProperty ;
               dc:identifier "SIO_000322" ;
               dcterms:description "A is spatiotemporally related to B iff A is in the spatial or temporal vicinity of B"@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is spatiotemporally related to"@en .


###  http://semanticscience.org/resource/SIO_000325
sio:SIO_000325 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000322 ;
