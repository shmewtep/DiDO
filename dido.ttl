                        owl:ReflexiveProperty ;
               owl:propertyChainAxiom ( sio:SIO_000325
                                        sio:SIO_000068
                                      ) ;
               dc:identifier "SIO_000325" ;
               dcterms:description "A overlaps with B iff there is some C that is part of both A and B. [S][R]"@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "overlaps with"@en .


