@prefix : <https://purl.org/dido/dido.owl#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix ex: <http://example.org/instance/> .
@prefix ont: <http://example.org/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sio: <http://semanticscience.org/resource/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix cito: <http://purl.org/spar/cito/> .
@prefix dcam: <http://purl.org/dc/dcam/> .
@prefix dcat: <http://www.w3.org/ns/dcat#/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix powla: <http://purl.org/powla/powla.owl#> .
@prefix schema: <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix protege: <http://protege.stanford.edu/plugins/owl/protege#> .
@prefix schema1: <http://schema.org/> .
@base <https://purl.org/dido/dido.owl> .

<https://purl.org/dido/dido.owl> rdf:type owl:Ontology ;
                                  owl:versionIRI <https://purl.org/dido/releases/2026-04-20/dido.owl> ;
                                  dc:creator "Kelsey Rook"@en ;
                                  dcterms:description "The Dialogue and Discourse Ontology (DIDO) supports the modeling of dialogue and dialogue data." ;
                                  dcterms:license "https://opensource.org/license/mit"^^xsd:anyURI ;
                                  dcterms:modified "2026-2-4" ;
                                  dcterms:title "Dialogue and Discourse Ontology (DiDO)" ;
                                  vann:preferredNamespacePrefix "dido" ;
                                  vann:preferredNamespaceUri "http://purl.org/twc/dido#" ;
                                  schema1:codeRepository "https://github.com/shmewtep/dialogueOnt"^^xsd:anyURI ;
                                  rdfs:label "DIDO" ;
                                  owl:versionInfo "2026-04-20" .

#################################################################
#    Annotation properties
#################################################################

###  http://protege.stanford.edu/plugins/owl/protege#defaultLanguage
protege:defaultLanguage rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/dcam/rangeIncludes
dcam:rangeIncludes rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/contributor
dc:contributor rdf:type owl:AnnotationProperty ;
               dc:identifier "contributor" .


###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty ;
           dc:identifier "creator" .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/identifier
dc:identifier rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/source
dc:source rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/alternative
dcterms:alternative rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/contributor
dcterms:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/isVersionOf
dcterms:isVersionOf rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
dcterms:publisher rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/rights
dcterms:rights rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://purl.org/ontology/bibo/editor
bibo:editor rdf:type owl:AnnotationProperty .


###  http://purl.org/ontology/bibo/translator
bibo:translator rdf:type owl:AnnotationProperty .


###  http://purl.org/spar/cito/citesAsAuthority
cito:citesAsAuthority rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty ;
                              dc:identifier "preferredNamespacePrefix" .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty ;
                           dc:identifier "preferredNamespaceUri" .


###  http://rdfs.org/ns/void#subset
void:subset rdf:type owl:AnnotationProperty .


###  http://schema.org/codeRepository
schema1:codeRepository rdf:type owl:AnnotationProperty .


###  http://schema.org/comment
schema1:comment rdf:type owl:AnnotationProperty .


###  http://semanticscience.org/resource/equivalentTo
sio:equivalentTo rdf:type owl:AnnotationProperty .


###  http://semanticscience.org/resource/subset
sio:subset rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#comment
rdfs:comment rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#deprecated
owl:deprecated rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#changeNote
skos:changeNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "definition"@en ;
                skos:definition "A statement or formal explanation of the meaning of a concept."@en .


###  http://www.w3.org/2004/02/skos/core#editorialNote
skos:editorialNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#historyNote
skos:historyNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/adms#versionNotes
adms:versionNotes rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#category
prov:category rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/prov#component
prov:component rdf:type owl:AnnotationProperty ;
               rdfs:comment "Classify prov-o terms into six components according to prov-dm, including 'agents-responsibility', 'alternate', 'annotations', 'collections', 'derivations', and 'entities-activities'. This classification is used so that readers of prov-o specification can find its correspondence with the prov-dm specification."@en ;
               rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> .


###  http://www.w3.org/ns/prov#definition
prov:definition rdf:type owl:AnnotationProperty ;
                rdfs:comment "A definition quoted from PROV-DM or PROV-CONSTRAINTS that describes the concept expressed with this OWL term."@en ;
                rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> .


###  http://www.w3.org/ns/prov#inverse
prov:inverse rdf:type owl:AnnotationProperty ;
             rdfs:comment "PROV-O does not define all property inverses. The directionalities defined in PROV-O should be given preference over those not defined. However, if users wish to name the inverse of a PROV-O property, the local name given by prov:inverse should be used."@en ;
             rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
             rdfs:seeAlso <http://www.w3.org/TR/prov-o/#names-of-inverse-properties> .


###  http://www.w3.org/ns/prov#qualifiedForm
prov:qualifiedForm rdf:type owl:AnnotationProperty ;
                   rdfs:comment """This annotation property links a subproperty of prov:wasInfluencedBy with the subclass of prov:Influence and the qualifying property that are used to qualify it. 

Example annotation:

    prov:wasGeneratedBy prov:qualifiedForm prov:qualifiedGeneration, prov:Generation .

Then this unqualified assertion:

    :entity1 prov:wasGeneratedBy :activity1 .

can be qualified by adding:

   :entity1 prov:qualifiedGeneration :entity1Gen .
   :entity1Gen 
       a prov:Generation, prov:Influence;
       prov:activity :activity1;
       :customValue 1337 .

Note how the value of the unqualified influence (prov:wasGeneratedBy :activity1) is mirrored as the value of the prov:activity (or prov:entity, or prov:agent) property on the influence class."""@en ;
                   rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> .


###  http://xmlns.com/foaf/0.1/depiction
foaf:depiction rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://purl.org/powla/powla.owl#firstTerminal
powla:firstTerminal rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf powla:hasTerminal ;
                    rdfs:domain powla:Nonterminal ;
                    rdfs:range powla:Terminal .


###  http://purl.org/powla/powla.owl#hasChild
powla:hasChild rdf:type owl:ObjectProperty ;
               owl:inverseOf powla:hasParent ;
               rdfs:domain powla:Nonterminal ;
               rdfs:range powla:Node ;
               rdfs:comment "OPTIONAL PROPERTY for expressing hierarchical annotations with coverage inheritance, e.g., in a tree annotation. Inverse of powla:hasParent, see there for details."@en .


###  http://purl.org/powla/powla.owl#hasDocument
powla:hasDocument rdf:type owl:ObjectProperty ;
                  rdfs:domain powla:DocumentLayer ;
                  rdfs:range powla:Document .


###  http://purl.org/powla/powla.owl#hasLayer
powla:hasLayer rdf:type owl:ObjectProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( powla:Node
                                           powla:Relation
                                         )
                           ] ;
               rdfs:range powla:DocumentLayer ;
               rdfs:comment """OPTIONAL object property
hasLayer assigns a Relation or a Node a an annotation layer. hasLayer is recommended for Root nodes; a root can have at most one layer."""@en .


###  http://purl.org/powla/powla.owl#hasNode
powla:hasNode rdf:type owl:ObjectProperty ;
              rdfs:domain powla:Root ;
              rdfs:range powla:Node .


###  http://purl.org/powla/powla.owl#hasNonterminal
powla:hasNonterminal rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf powla:hasNode ;
                     rdfs:domain powla:Root ;
                     rdfs:range powla:Nonterminal .


###  http://purl.org/powla/powla.owl#hasParent
powla:hasParent rdf:type owl:ObjectProperty ;
                rdfs:domain powla:Node ;
                rdfs:range powla:Nonterminal ;
                rdfs:comment """RECOMMENDED PROPERTY for expressing hierarchical annotations with coverage inheritance, e.g., in a tree annotation. 

Coverage inheritance means that the string covered by the children must also be covered by the parent node. A typical example is phrase-structure syntax. A typical counter-example is dependency syntax."""@en .


###  http://purl.org/powla/powla.owl#hasRoot
powla:hasRoot rdf:type owl:ObjectProperty ;
              rdfs:domain powla:Node ;
              rdfs:range powla:Root ;
              rdfs:comment """OPTIONAL object property
powla:hasRoot is useful for efficient querying, as it allows to quickly check whether two nodes are part of the same tree structure (i.e., they have the same root). However, this is a derived property and SHOULD NOT be provided when exchanging POWLA datasets.

This is an optional shorthand for 
?node powla:hasParent+ ?root MINUS {?root powla:hasParent [] }"""@en .


###  http://purl.org/powla/powla.owl#hasSource
powla:hasSource rdf:type owl:ObjectProperty ;
                owl:inverseOf powla:isSourceOf ;
                rdfs:domain powla:Relation ;
                rdfs:range powla:Node ;
                rdfs:comment "RECOMMENDED datatype property for expressing annotated relations with powla:Relaton."@en .


###  http://purl.org/powla/powla.owl#hasSubDocument
powla:hasSubDocument rdf:type owl:ObjectProperty ;
                     owl:inverseOf powla:hasSuperDocument ;
                     rdfs:domain powla:Document ;
                     rdfs:range powla:Document .


###  http://purl.org/powla/powla.owl#hasSuperDocument
powla:hasSuperDocument rdf:type owl:ObjectProperty ;
                       rdfs:domain powla:Document ;
                       rdfs:range powla:Document .


###  http://purl.org/powla/powla.owl#hasTarget
powla:hasTarget rdf:type owl:ObjectProperty ;
                owl:inverseOf powla:isTargetOf ;
                rdfs:domain powla:Relation ;
                rdfs:range powla:Node ;
                rdfs:comment "RECOMMENDED datatype property for expressing annotated relations with powla:Relaton."@en .


###  http://purl.org/powla/powla.owl#hasTerminal
powla:hasTerminal rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf powla:hasNode ;
                  rdfs:domain powla:Root ;
                  rdfs:range powla:Terminal .


###  http://purl.org/powla/powla.owl#isSourceOf
powla:isSourceOf rdf:type owl:ObjectProperty ;
                 rdfs:domain powla:Node ;
                 rdfs:range powla:Relation ;
                 rdfs:comment "OPTIONAL datatype property for expressing annotated relations with powla:Relaton. Inverse of powla:hasSource."@en .


###  http://purl.org/powla/powla.owl#isTargetOf
powla:isTargetOf rdf:type owl:ObjectProperty ;
                 rdfs:domain powla:Node ;
                 rdfs:range powla:Relation ;
                 rdfs:comment "OPTIONAL  datatype property for expressing annotated relations with powla:Relaton. Inverse of powla:hasTarget"@en .


###  http://purl.org/powla/powla.owl#lastTerminal
powla:lastTerminal rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf powla:hasTerminal ;
                   rdfs:domain powla:Nonterminal ;
                   rdfs:range powla:Terminal .


###  http://purl.org/powla/powla.owl#next
powla:next rdf:type owl:ObjectProperty ;
           owl:inverseOf powla:previous ;
           rdfs:comment """OBLIGATORY PROPERTY for connecting two powla:Nodes in a sequence. Note that powla:next is not transitive, but should connect adjacent nodes only.

powla:next can be used to connect subsequent strings in *any* annotation, but when applied to an annotation layer with hierarchical annotation (e.g., a syntactic tree), it is recommended to use powla:next to express the order of nodes with the same parent (e.g., elements of a phrase) are to be connected. Note that sibling order may deviate from string order in the case of discontinuous annotations:

[ [What]_PP1 are [ [you]_SBJ talking [about]_PP2 ]_VP ] ?

In the example, the prepositional argument [about what]_PP is split (\"preposition stranding\"). Depending on the type of syntactic representation, it may be desirable to represent this as a single phrase, and POWLA allows to specify the canonical order of phrase elements regardless of their sequential order in the textual representation, i.e., about > what.

Note that powla:next MUST be cycle-free, so antisequential order SHOULD NOT be applied to externally provided URIs, e.g., NIF URIs or RFC 5147 URIs. As an alternative, these SHOULD be assigned blank nodes as powla:hasParent each, which are then connected by powla:next.

All children of the same parent node SHOULD be connected by a sequence of powla:next transitions. Non-siblings CAN be connected by powla:next, but this is not recommended except in the absence of hierarchical annotations.

Also note that a single powla:Node MAY have multiple powla:next properties *relative to different parent nodes*. These can be disambiguated with reference to the parent node."""@en .


###  http://purl.org/powla/powla.owl#nextNode
powla:nextNode rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf powla:next ;
               owl:inverseOf powla:previousNode ;
               rdfs:domain powla:Node ;
               rdfs:range powla:Node ;
               owl:deprecated "true"^^xsd:boolean ;
               owl:versionInfo "replaced by powla:next"@en .


###  http://purl.org/powla/powla.owl#previous
powla:previous rdf:type owl:ObjectProperty ;
               rdfs:comment "OPTIONAL PROPERTY for connecting two powla:Nodes in a sequence. Inverse of powla:next, see there for details."@en .


###  http://purl.org/powla/powla.owl#previousNode
powla:previousNode rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf powla:previous ;
                   rdfs:domain powla:Node ;
                   rdfs:range powla:Node ;
                   owl:deprecated "true"^^xsd:boolean ;
                   owl:versionInfo "deprecated in favor of powla:previous"@en .


###  http://purl.org/powla/powla.owl#rootOfDocument
powla:rootOfDocument rdf:type owl:ObjectProperty ;
                     rdfs:domain powla:DocumentLayer ;
                     rdfs:range powla:Root ;
                     rdfs:comment """DEPRECATED object property
connecting a DocumentLayer to the roots in the document."""@en ;
                     owl:deprecated "true"^^xsd:boolean ;
                     owl:versionInfo "deprecated in favor of powla:hasLayer (a partial inverse)"@en .


###  http://purl.org/twc/dido#hasAddressee
<http://purl.org/twc/dido#hasAddressee> rdf:type owl:ObjectProperty ;
                                        rdfs:subPropertyOf sio:SIO_000291 ;
                                        rdfs:label "has addressee" .


###  http://semanticscience.org/resource/SIO_000001
sio:SIO_000001 rdf:type owl:ObjectProperty ,
                        owl:SymmetricProperty ;
               rdfs:domain sio:SIO_000000 ;
               rdfs:range sio:SIO_000000 ;
               dc:identifier "SIO_000001" ;
               dcterms:description "A is related to B iff there is some relation between A and B."@en ;
               schema1:comment "'is related to' is the top level relation in SIO" ;
               sio:subset "core" ,
                          "relations+" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is related to"@en .


###  http://semanticscience.org/resource/SIO_000008
sio:SIO_000008 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000001 ;
               owl:inverseOf sio:SIO_000011 ;
               rdfs:domain sio:SIO_000000 ;
               dc:identifier "SIO_000008" ;
               dcterms:description "has attribute is a relation that associates a entity with an attribute where an attribute is an intrinsic characteristic such as a quality, capability, disposition, function, or is an externally derived attribute determined from some descriptor (e.g. a quantity, position, label/identifier) either directly or indirectly through generalization of entities of the same type."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has attribute"@en .


###  http://semanticscience.org/resource/SIO_000011
sio:SIO_000011 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000001 ;
               dc:identifier "SIO_000011" ;
               dcterms:description "is attribute of is a relation that associates an attribute with an entity where an attribute is an intrinsic characteristic such as a quality, capability, disposition, function, or is an externally derived attribute determined from some descriptor (e.g. a quantity, position, label/identifier) either directly or indirectly through generalization of entities of the same type."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is attribute of"@en .


###  http://semanticscience.org/resource/SIO_000028
sio:SIO_000028 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000145 ;
               owl:inverseOf sio:SIO_000068 ;
               rdf:type owl:TransitiveProperty ,
                        owl:ReflexiveProperty ;
               dc:identifier "SIO_000028" ;
               dcterms:description "has part is a transitive, reflexive and antisymmetric relation between a whole and itself or a whole and its part."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has part"@en ;
               skos:example "a collection of cars has as a car as a part;a car has an engine as a part; a car has a piston as a part;"@en .


###  http://semanticscience.org/resource/SIO_000053
sio:SIO_000053 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000028 ;
               owl:inverseOf sio:SIO_000093 ;
               rdf:type owl:AsymmetricProperty ,
                        owl:IrreflexiveProperty ;
               dc:identifier "SIO_000053" ;
               dcterms:description "has proper part is an antisymmetric, irreflexive (normally transitive) relation between a whole and a distinct part."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has proper part"@en ;
               skos:example "a car has an engine as a proper part; a car has a piston as a proper part;"@en .


###  http://semanticscience.org/resource/SIO_000059
sio:SIO_000059 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000008 ;
               owl:inverseOf sio:SIO_000095 ;
               rdf:type owl:IrreflexiveProperty ;
               rdfs:domain sio:SIO_000616 ;
               dc:identifier "SIO_000059" ;
               dcterms:description "has member is a mereological relation between a collection and an item."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has member"@en ;
               skos:example "a collection of cars has as a car as a member"@en .


###  http://semanticscience.org/resource/SIO_000061
sio:SIO_000061 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000322 ;
               owl:inverseOf sio:SIO_000145 ;
               rdf:type owl:TransitiveProperty ;
               dc:identifier "SIO_000061" ;
               dcterms:description "A is located in B iff the spatialtemporial region occupied by A is part of the spatialtemporal region occupied by B. [T][R]"@en ;
               sio:equivalentTo "OBO_REL:located_in" ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is located in"@en ;
               skos:example "A parasite in the interior of a person's intestine is located in their intestinal lumen."@en .


###  http://semanticscience.org/resource/SIO_000062
sio:SIO_000062 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000322 ;
               owl:inverseOf sio:SIO_000132 ;
               rdfs:range sio:SIO_000006 ;
               dc:identifier "SIO_000062" ;
               dcterms:description "is participant in is a relation that describes the participation of the subject in the (processual) object."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is participant in"@en ;
               skos:example "a car is a participant in a car race; glucose is a participant in glycolysis"@en .


###  http://semanticscience.org/resource/SIO_000063
sio:SIO_000063 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000062 ;
               owl:inverseOf sio:SIO_000139 ;
               dc:identifier "SIO_000063" ;
               dcterms:description "is agent in is a relation between an entity and a process, where the entity is present throughout the process, no permanent material change occurs, and is a causal participant in the process."@en ;
               sio:subset "sadi"@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is agent in"@en ;
               skos:example "hexokinase is an agent in the conversion of glucose to glucose-6-phosphate"@en .


###  http://semanticscience.org/resource/SIO_000068
sio:SIO_000068 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000061 ;
               rdf:type owl:TransitiveProperty ,
                        owl:ReflexiveProperty ;
               dc:identifier "SIO_000068" ;
               dcterms:description "is part of is a transitive, reflexive and anti-symmetric mereological relation between a whole and itself or a part and its whole."@en ;
               sio:equivalentTo "OBO_REL:part_of" ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is part of"@en .


