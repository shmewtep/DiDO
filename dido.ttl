###  http://semanticscience.org/resource/SIO_001431
sio:SIO_001431 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_001429 ;
               dc:identifier "SIO_001431" ;
               dcterms:alternative "rank 0 tensor"@en ;
