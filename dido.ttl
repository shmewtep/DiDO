<https://purl.org/dido/dido.owl> rdf:type owl:Ontology ;
                                  owl:versionIRI <https://purl.org/dido/releases/2026-02-25/dido.owl> ;
                                  dc:creator "Kelsey Rook"@en ;
                                  dcterms:description "The Dialogue and Discourse Ontology (DIDO) supports the modeling of dialogue and dialogue data." ;
                                  dcterms:license "https://opensource.org/license/mit"^^xsd:anyURI ;
                                  dcterms:modified "2026-2-4" ;
                                  dcterms:title "Dialogue and Discourse Ontology (DiDO)" ;
                                  vann:preferredNamespacePrefix "dido" ;
                                  vann:preferredNamespaceUri "http://purl.org/twc/dido#" ;
                                  schema1:codeRepository "https://github.com/shmewtep/dialogueOnt"^^xsd:anyURI ;
                                  rdfs:label "DIDO" ;
                                  owl:versionInfo "2026-02-25" .

