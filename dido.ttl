###  http://semanticscience.org/resource/SIO_000268
sio:SIO_000268 rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Class ;
                                     owl:unionOf ( sio:SIO_000269
                                                   sio:SIO_000270
                                                 )
                                   ] ;
