xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://semanticscience.org/resource/SIO_000001
sio:SIO_000001 rdf:type owl:ObjectProperty ,
                        owl:SymmetricProperty ;
               rdfs:domain sio:SIO_000000 ;
               rdfs:range sio:SIO_000000 ;
               dc:identifier "SIO_000001" ;
               dcterms:description "A is related to B iff there is some relation between A and B."@en ;
               schema1:comment "'is related to' is the top level relation in SIO" ;
               sio:subset "core" ,
                          "relations+" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is related to"@en .


###  http://semanticscience.org/resource/SIO_000008
sio:SIO_000008 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000001 ;
               owl:inverseOf sio:SIO_000011 ;
               rdfs:domain sio:SIO_000000 ;
               dc:identifier "SIO_000008" ;
               dcterms:description "has attribute is a relation that associates a entity with an attribute where an attribute is an intrinsic characteristic such as a quality, capability, disposition, function, or is an externally derived attribute determined from some descriptor (e.g. a quantity, position, label/identifier) either directly or indirectly through generalization of entities of the same type."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has attribute"@en .


###  http://semanticscience.org/resource/SIO_000011
sio:SIO_000011 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000001 ;
               dc:identifier "SIO_000011" ;
               dcterms:description "is attribute of is a relation that associates an attribute with an entity where an attribute is an intrinsic characteristic such as a quality, capability, disposition, function, or is an externally derived attribute determined from some descriptor (e.g. a quantity, position, label/identifier) either directly or indirectly through generalization of entities of the same type."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is attribute of"@en .


###  http://semanticscience.org/resource/SIO_000028
sio:SIO_000028 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000145 ;
               owl:inverseOf sio:SIO_000068 ;
               rdf:type owl:TransitiveProperty ,
                        owl:ReflexiveProperty ;
               dc:identifier "SIO_000028" ;
               dcterms:description "has part is a transitive, reflexive and antisymmetric relation between a whole and itself or a whole and its part."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has part"@en ;
               skos:example "a collection of cars has as a car as a part;a car has an engine as a part; a car has a piston as a part;"@en .


###  http://semanticscience.org/resource/SIO_000053
sio:SIO_000053 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000028 ;
               owl:inverseOf sio:SIO_000093 ;
               rdf:type owl:AsymmetricProperty ,
                        owl:IrreflexiveProperty ;
               dc:identifier "SIO_000053" ;
               dcterms:description "has proper part is an antisymmetric, irreflexive (normally transitive) relation between a whole and a distinct part."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has proper part"@en ;
               skos:example "a car has an engine as a proper part; a car has a piston as a proper part;"@en .


###  http://semanticscience.org/resource/SIO_000059
sio:SIO_000059 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000008 ;
               owl:inverseOf sio:SIO_000095 ;
               rdf:type owl:IrreflexiveProperty ;
               rdfs:domain sio:SIO_000616 ;
               dc:identifier "SIO_000059" ;
               dcterms:description "has member is a mereological relation between a collection and an item."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has member"@en ;
               skos:example "a collection of cars has as a car as a member"@en .


###  http://semanticscience.org/resource/SIO_000061
sio:SIO_000061 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000322 ;
               owl:inverseOf sio:SIO_000145 ;
               rdf:type owl:TransitiveProperty ;
               dc:identifier "SIO_000061" ;
               dcterms:description "A is located in B iff the spatialtemporial region occupied by A is part of the spatialtemporal region occupied by B. [T][R]"@en ;
               sio:equivalentTo "OBO_REL:located_in" ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is located in"@en ;
               skos:example "A parasite in the interior of a person's intestine is located in their intestinal lumen."@en .


###  http://semanticscience.org/resource/SIO_000062
sio:SIO_000062 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000322 ;
               owl:inverseOf sio:SIO_000132 ;
               rdfs:range sio:SIO_000006 ;
               dc:identifier "SIO_000062" ;
               dcterms:description "is participant in is a relation that describes the participation of the subject in the (processual) object."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is participant in"@en ;
               skos:example "a car is a participant in a car race; glucose is a participant in glycolysis"@en .


###  http://semanticscience.org/resource/SIO_000063
sio:SIO_000063 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000062 ;
               owl:inverseOf sio:SIO_000139 ;
               dc:identifier "SIO_000063" ;
               dcterms:description "is agent in is a relation between an entity and a process, where the entity is present throughout the process, no permanent material change occurs, and is a causal participant in the process."@en ;
               sio:subset "sadi"@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is agent in"@en ;
               skos:example "hexokinase is an agent in the conversion of glucose to glucose-6-phosphate"@en .


###  http://semanticscience.org/resource/SIO_000068
sio:SIO_000068 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000061 ;
               rdf:type owl:TransitiveProperty ,
                        owl:ReflexiveProperty ;
               dc:identifier "SIO_000068" ;
               dcterms:description "is part of is a transitive, reflexive and anti-symmetric mereological relation between a whole and itself or a part and its whole."@en ;
               sio:equivalentTo "OBO_REL:part_of" ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is part of"@en .


###  http://semanticscience.org/resource/SIO_000093
sio:SIO_000093 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000068 ;
               rdf:type owl:AsymmetricProperty ,
                        owl:IrreflexiveProperty ;
               dc:identifier "SIO_000093" ;
               dcterms:description "is proper part of is an asymmetric, irreflexive (normally transitive) relation between a part and its distinct whole."@en ;
               sio:equivalentTo "OBO_REL:proper_part_of" ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is proper part of"@en .


###  http://semanticscience.org/resource/SIO_000095
sio:SIO_000095 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000011 ;
               dc:identifier "SIO_000095" ;
               dcterms:description "is member of is a mereological relation between a item and a collection."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is member of"@en .


###  http://semanticscience.org/resource/SIO_000132
sio:SIO_000132 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000322 ;
               rdfs:domain sio:SIO_000006 ;
               dc:identifier "SIO_000132" ;
               dcterms:description "has participant is a relation that describes the participation of the object in the (processual) subject."@en ;
               sio:equivalentTo "OBO_REL:has_participant" ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has participant"@en .


###  http://semanticscience.org/resource/SIO_000139
sio:SIO_000139 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000132 ;
               dc:identifier "SIO_000139" ;
               dcterms:description "has agent is a relation between a process and an entity, where the entity is present throughout the process and is a causal participant in the process."@en ;
               sio:equivalentTo "OBO_REL:has_agent" ;
               sio:subset "core" ,
                          "sadi"@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has agent"@en .


###  http://semanticscience.org/resource/SIO_000145
sio:SIO_000145 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000322 ;
               rdf:type owl:TransitiveProperty ;
               dc:identifier "SIO_000145" ;
               dcterms:description "A is location of B iff the spatialtemporal region occupied by A has the spatialtemporal region occupied by B as a part. [T][R]"@en ;
               sio:subset "nlp+" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is location of"@en .


###  http://semanticscience.org/resource/SIO_000212
sio:SIO_000212 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000001 ;
               owl:inverseOf sio:SIO_000628 ;
               dc:identifier "SIO_000212" ;
               dcterms:description "A is referred to by B iff B is an informational entity that makes reference to A."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is referred to by"@en .


###  http://semanticscience.org/resource/SIO_000213
sio:SIO_000213 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000425 ;
               owl:inverseOf sio:SIO_000214 ;
               dc:identifier "SIO_000213" ;
               dcterms:description "A has concretization B iff A is an informational entity and B is the a quality of some material entity."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has concretization"@en .


###  http://semanticscience.org/resource/SIO_000214
sio:SIO_000214 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000425 ;
               dc:identifier "SIO_000214" ;
               dcterms:description "A is concretization of B iff A is a quality of a material entity and B is an informational entity."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is concretization of"@en .


###  http://semanticscience.org/resource/SIO_000215
sio:SIO_000215 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000011 ;
               owl:inverseOf sio:SIO_000216 ;
               rdfs:domain sio:SIO_000070 ;
               dc:identifier "SIO_000215" ;
               dcterms:description "is measurement value of is a relation between a value and the entity that it is a measurement of."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is measurement value of"@en .


###  http://semanticscience.org/resource/SIO_000216
sio:SIO_000216 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000008 ;
               rdfs:range sio:SIO_000070 ;
               dc:identifier "SIO_000216" ;
               dcterms:description "has measurement value is a relation between a quality/realizable and a measurement value."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has measurement value"@en .


###  http://semanticscience.org/resource/SIO_000217
sio:SIO_000217 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000223 ;
               owl:inverseOf sio:SIO_000218 ;
               rdf:type owl:InverseFunctionalProperty ;
               rdfs:range sio:SIO_000005 ;
               dc:identifier "SIO_000217" ;
               dcterms:description "has quality is a relation between an entity and the quality that it bears."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has quality"@en .


###  http://semanticscience.org/resource/SIO_000218
sio:SIO_000218 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000224 ;
               rdfs:domain sio:SIO_000005 ;
               dc:identifier "SIO_000218" ;
               dcterms:description "is quality of is a relation between a quality and the entity that it is a property of."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is quality of"@en .


###  http://semanticscience.org/resource/SIO_000221
sio:SIO_000221 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000008 ;
               owl:inverseOf sio:SIO_000222 ;
               rdf:type owl:FunctionalProperty ;
               rdfs:domain sio:SIO_000075 ;
               rdfs:range sio:SIO_000074 ;
               dc:identifier "SIO_000221" ;
               dcterms:description "has unit is a relation between a quantity and the unit it is a multiple of."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has unit"@en .


###  http://semanticscience.org/resource/SIO_000222
sio:SIO_000222 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000011 ;
               rdfs:domain sio:SIO_000074 ;
               dc:identifier "SIO_000222" ;
               dcterms:description "is unit of is a relation between a unit and a quantity that it is a multiple of."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is unit of"@en .


###  http://semanticscience.org/resource/SIO_000223
sio:SIO_000223 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000008 ;
               owl:inverseOf sio:SIO_000224 ;
               rdf:type owl:InverseFunctionalProperty ;
               dc:identifier "SIO_000223" ;
               dcterms:description "has property is a relation between an entity and the quality, capability or role that it and it alone bears."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has property"@en ;
               skos:example "michel's hair has the quality of being brown in colour."@en .


###  http://semanticscience.org/resource/SIO_000224
sio:SIO_000224 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000011 ;
               rdf:type owl:FunctionalProperty ;
               dc:identifier "SIO_000224" ;
               dcterms:description "is property of is a relation betweena  quality, capability or role and the entity that it and it alone bears."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is property of"@en .


