                                 owl:hasValue "true"^^xsd:boolean
                               ] ;
               owl:disjointWith sio:SIO_000270 ;
               dc:identifier "SIO_000269" ;
               dcterms:description "true is a truth value that indicates that it holds under all possible worlds."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "true"@en .


