               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is base for"@en ;
               skos:example "the solubility of salt (the disposition) is based on the molecular structure of NaCl (the quality) that allows the polarized water-molecules (the trigger)  to break the ion bonds (the realization)."@en .


###  http://semanticscience.org/resource/SIO_000643
sio:SIO_000643 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000224 ;
               owl:inverseOf sio:SIO_000644 ;
               rdf:type owl:FunctionalProperty ;
               dc:identifier "SIO_000643" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is realizable property of"@en .


###  http://semanticscience.org/resource/SIO_000644
sio:SIO_000644 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000223 ;
               rdf:type owl:InverseFunctionalProperty ;
               dc:identifier "SIO_000644" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has realizable property"@en .


###  http://semanticscience.org/resource/SIO_000646
sio:SIO_000646 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000643 ;
               rdf:type owl:FunctionalProperty ;
               rdfs:domain sio:SIO_000112 ;
               dc:identifier "SIO_000646" ;
               dcterms:description "is capability of is a relation between a capability and the entity that bears it."@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is capability of"@en .


###  http://semanticscience.org/resource/SIO_000671
sio:SIO_000671 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000008 ;
               owl:inverseOf sio:SIO_000672 ;
               rdfs:range sio:SIO_000115 ;
               dc:identifier "SIO_000671" ;
               dcterms:description "a relation between an entity and an identifier." ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has identifier"@en .


###  http://semanticscience.org/resource/SIO_000672
sio:SIO_000672 rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf sio:SIO_000011 ;
               rdfs:domain sio:SIO_000115 ;
               dc:identifier "SIO_000672" ;
               dcterms:alternative "identifies" ;
               dcterms:description "a relation between an identifier and an entity." ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "is identifier for"@en .


###  http://www.w3.org/2006/time#hasBeginning
time:hasBeginning rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf time:hasTime ;
                  rdfs:domain time:TemporalEntity ;
                  rdfs:range time:Instant ;
                  rdfs:comment "Beginning of a temporal entity"@en ,
                               "Comienzo de una entidad temporal."@es ;
                  rdfs:label "has beginning"@en ,
                             "tiene principio"@es ;
                  skos:definition "Beginning of a temporal entity."@en ,
                                  "Comienzo de una entidad temporal."@es .


###  http://www.w3.org/2006/time#hasEnd
time:hasEnd rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf time:hasTime ;
            rdfs:domain time:TemporalEntity ;
            rdfs:range time:Instant ;
            rdfs:comment "End of a temporal entity."@en ,
                         "Final de una entidad temporal."@es ;
            rdfs:label "has end"@en ,
                       "tiene fin"@es ;
            skos:definition "End of a temporal entity."@en ,
                            "Final de una entidad temporal."@es .


###  http://www.w3.org/2006/time#hasTRS
time:hasTRS rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain [ rdf:type owl:Class ;
                          owl:unionOf ( time:GeneralDurationDescription
                                        time:TemporalPosition
                                      )
                        ] ;
            rdfs:comment "El sistema de referencia temporal utilizado por una posición temporal o descripción de extensión."@es ,
                         "The temporal reference system used by a temporal position or extent description. "@en ;
            rdfs:label "Temporal reference system used"@en ,
                       "sistema de referencia temporal utilizado"@es ;
            skos:definition "El sistema de referencia temporal utilizado por una posición temporal o descripción de extensión."@es ,
                            "The temporal reference system used by a temporal position or extent description. "@en .


###  http://www.w3.org/2006/time#hasTime
time:hasTime rdf:type owl:ObjectProperty ;
             rdfs:range time:TemporalEntity ;
             rdfs:comment "Proporciona soporte a la asociación de una entidad temporal (instante o intervalo) a cualquier cosa."@es ,
                          "Supports the association of a temporal entity (instant or interval) to any thing"@en ;
             rdfs:label "has time"@en ,
                        "tiene tiempo"@es ;
             skos:definition "Proporciona soporte a la asociación de una entidad temporal (instante o intervalo) a cualquier cosa."@es ,
                             "Supports the association of a temporal entity (instant or interval) to any thing"@en ;
             skos:editorialNote "Característica arriesgada -añadida en la revisión del 2017 que no ha sido todavía utilizada de forma amplia."@es ,
                                "Feature at risk - added in 2017 revision, and not yet widely used. "@en .


###  http://www.w3.org/2006/time#inDateTime
time:inDateTime rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf time:inTemporalPosition ;
                rdfs:domain time:Instant ;
                rdfs:range time:GeneralDateTimeDescription ;
                rdfs:comment "Posición de un instante, expresada utilizando una descripción estructurada."@es ,
                             "Position of an instant, expressed using a structured description"@en ;
                rdfs:label "en descripción de fecha-hora"@es ,
                           "in date-time description"@en ;
                skos:definition "Posición de un instante, expresada utilizando una descripción estructurada."@es ,
                                "Position of an instant, expressed using a structured description"@en .


###  http://www.w3.org/2006/time#inTemporalPosition
time:inTemporalPosition rdf:type owl:ObjectProperty ;
                        rdfs:domain time:Instant ;
                        rdfs:range time:TemporalPosition ;
                        rdfs:comment "Posición de un instante de tiempo."@es ,
                                     "Position of a time instant"@en ;
                        rdfs:label "Temporal position"@en ,
                                   "posición temporal"@es ;
                        skos:definition "Posición de un instante de tiempo."@es ,
                                        "Position of a time instant"@en .


###  http://www.w3.org/2006/time#unitType
time:unitType rdf:type owl:ObjectProperty ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( time:Duration
                                          time:GeneralDateTimeDescription
                                        )
                          ] ;
              rdfs:comment "La unidad de tiempo que proporciona la precisión de un valor fecha-hora o la escala de una extensión temporal."@es ,
                           "The temporal unit which provides the precision of a date-time value or scale of a temporal extent"@en ;
              rdfs:label "temporal unit type"@en ,
                         "tipo de unidad temporal"@es .


###  http://www.w3.org/ns/dcat#landingPage
<http://www.w3.org/ns/dcat#landingPage> rdf:type owl:ObjectProperty ;
                                        rdfs:comment "A Web page that can be navigated to in a Web browser to gain access to the catalog, a dataset, its distributions and/or additional information."@en ,
                                                     "En webside som der kan navigeres til i en webbrowser for at få adgang til kataloget, et datasæt, dets distributioner og/eller yderligere information."@da ,
                                                     "Una pagina web che può essere navigata per ottenere l'accesso al catalogo, ad un dataset, alle distribuzioni del dataset e/o ad informazioni addizionali."@it ,
                                                     "Una página web que puede ser visitada en un explorador Web para tener acceso el catálogo, un conjunto de datos, sus distribuciones y/o información adicional."@es ,
                                                     "Une page Web accessible par un navigateur Web donnant accès au catalogue, un jeu de données, ses distributions et/ou des informations additionnelles."@fr ,
                                                     "Webová stránka, na kterou lze pro získání přístupu ke katalogu, datové sadě, jejím distribucím a/nebo dalším informacím přistoupit webovým prohlížečem."@cs ,
                                                     "Μία ιστοσελίδα πλοηγίσιμη μέσω ενός φυλλομετρητή (Web browser) που δίνει πρόσβαση στο σύνολο δεδομένων, τις διανομές αυτού ή/και επιπρόσθετες πληροφορίες."@el ,
                                                     "صفحة وب يمكن من خلالها الوصول الى قائمة البيانات أو إلى معلومات إضافية متعلقة بها "@ar ,
                                                     "データセット、その配信および（または）追加情報にアクセスするためにウエブ・ブラウザでナビゲートできるウェブページ。"@ja ;
                                        rdfs:isDefinedBy <http://www.w3.org/TR/vocab-dcat/> ;
                                        rdfs:label "destinationsside"@da ,
                                                   "landing page"@en ,
                                                   "page d'atterrissage"@fr ,
                                                   "pagina di destinazione"@it ,
                                                   "página de destino"@es ,
                                                   "vstupní stránka"@cs ,
                                                   "ιστοσελίδα αρχικής πρόσβασης"@el ,
                                                   "صفحة وصول"@ar ,
                                                   "ランディング・ページ"@ja ;
                                        skos:definition "A Web page that can be navigated to in a Web browser to gain access to the catalog, a dataset, its distributions and/or additional information."@en ,
                                                        "En webside som en webbrowser kan navigeres til for at få adgang til kataloget, et datasæt, dets distritbutioner og/eller yderligere information."@da ,
                                                        "Una pagina web che può essere navigata per ottenere l'accesso al catalogo, ad un dataset, alle distribuzioni del dataset e/o ad informazioni addizionali."@it ,
                                                        "Una página web que puede ser visitada en un explorador Web para tener acceso el catálogo, un conjunto de datos, sus distribuciones y/o información adicional."@es ,
                                                        "Une page Web accessible par un navigateur Web donnant accès au catalogue, un jeu de données, ses distributions et/ou des informations additionnelles."@fr ,
                                                        "Webová stránka, na kterou lze pro získání přístupu ke katalogu, datové sadě, jejím distribucím a/nebo dalším informacím přistoupit webovým prohlížečem."@cs ,
                                                        "Μία ιστοσελίδα πλοηγίσιμη μέσω ενός φυλλομετρητή (Web browser) που δίνει πρόσβαση στο σύνολο δεδομένων, τις διανομές αυτού ή/και επιπρόσθετες πληροφορίες."@el ,
                                                        "صفحة وب يمكن من خلالها الوصول الى قائمة البيانات أو إلى معلومات إضافية متعلقة بها "@ar ,
                                                        "データセット、その配信および（または）追加情報にアクセスするためにウエブ・ブラウザでナビゲートできるウェブページ。"@ja ;
                                        skos:scopeNote "Hvis en eller flere distributioner kun er tilgængelige via en destinationsside (dvs. en URL til direkte download er ikke kendt), så bør destinationssidelinket gentages som adgangsadresse for en distribution."@da ,
                                                       "If the distribution(s) are accessible only through a landing page (i.e. direct download URLs are not known), then the landing page link should be duplicated as accessURL on a distribution."@en ,
                                                       "Pokud je distribuce dostupná pouze přes vstupní stránku, t.j. přímý URL odkaz ke stažení není znám, URL přístupové stránky by mělo být duplikováno ve vlastnosti distribuce accessURL."@cs ,
                                                       "Se la distribuzione è accessibile solo attraverso una pagina di destinazione (cioè, un URL di download diretto non è noto), il link alla pagina di destinazione deve essere duplicato come accessURL sulla distribuzione."@it ,
                                                       "Si la distribución es accesible solamente través de una página de aterrizaje (i.e., no se conoce una URL de descarga directa), entonces el enlance a la página de aterrizaje debe ser duplicado como accessURL sobre la distribución."@es ,
                                                       "Si la distribution est seulement accessible à travers une page d'atterrissage (exple. pas de connaissance d'URLS de téléchargement direct ), alors le lien de la page d'atterrissage doit être dupliqué comme accessURL sur la distribution."@fr ,
                                                       "Αν η/οι διανομή/ές είναι προσβάσιμη/ες μόνο μέσω μίας ιστοσελίδας αρχικής πρόσβασης (δηλαδή αν δεν υπάρχουν γνωστές διευθύνσεις άμεσης μεταφόρτωσης), τότε ο σύνδεσμος της ιστοσελίδας αρχικής πρόσβασης πρέπει να αναπαραχθεί ως accessURL σε μία διανομή."@el ,
                                                       "ランディング・ページを通じてしか配信にアクセスできない場合（つまり、直接的なダウンロードURLが不明）には、配信におけるaccessURLとしてランディング・ページのリンクをコピーすべきです（SHOULD）。"@ja .


###  http://www.w3.org/ns/prov#wasAttributedTo
prov:wasAttributedTo rdf:type owl:ObjectProperty ;
                     rdfs:comment "Attribution is the ascribing of an entity to an agent."@en ;
                     rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
                     rdfs:label "wasAttributedTo" ;
                     prov:category "starting-point" ;
                     prov:component "agents-responsibility" ;
                     prov:definition "Attribution is the ascribing of an entity to an agent."@en ;
                     prov:inverse "contributed" ;
                     prov:qualifiedForm prov:Attribution ,
                                        prov:qualifiedAttribution .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:DatatypeProperty .


###  http://purl.org/powla/powla.owl#documentID
powla:documentID rdf:type owl:DatatypeProperty ;
                 rdfs:domain powla:Document ;
                 rdfs:range xsd:string .


###  http://purl.org/powla/powla.owl#end
powla:end rdf:type owl:DatatypeProperty ;
          rdfs:domain powla:Node ;
          rdfs:range xsd:int ;
          rdfs:comment """OPTIONAL datatype property or powla:Node
RECOMMENDED datatype property for powla:Terminal

powla:end allows to specify a numerical (integer) index. This may be an offset (as in NIF) or a structure-sensitive index (as in ANNIS). Interpretation is implementation-specific, but end >= start."""@en .


###  http://purl.org/powla/powla.owl#endPosition
powla:endPosition rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf powla:end ;
                  rdfs:domain powla:Terminal ;
                  rdfs:range xsd:int ;
                  owl:deprecated "true"^^xsd:boolean ;
                  owl:versionInfo "DEPRECATED in favor of powla:end"@en .


###  http://purl.org/powla/powla.owl#hasAnnotation
powla:hasAnnotation rdf:type owl:DatatypeProperty ;
                    rdfs:domain powla:POWLAElement ;
                    rdfs:range xsd:string ;
                    rdfs:comment """ABSTRACT datatype property for linguistic annotations (on Node and Relation) and metadata (on Document and Layer).
hasAnnotation represents linguistic annotations. The atgtribute name is specified in the hasXY property, the value is the string value."""@en ;
                    owl:versionInfo """2018-04-01 generalized to metadata annotation
corresponds to labels attached to nodes and edges in SALT"""@en .


###  http://purl.org/powla/powla.owl#hasMetadata
powla:hasMetadata rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf powla:hasAnnotation ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( powla:Document
                                              powla:Layer
                                            )
                              ] ;
                  rdfs:comment """like hasAnnotation, but for Document and Layer

corresponds to labels attached to Graphs in SALT""" ;
                  owl:deprecated "true"^^xsd:boolean ;
                  owl:versionInfo "deprecatred in favor of (a generalization of) powla:hasAnnotation"@en .


###  http://purl.org/powla/powla.owl#hasStringValue
powla:hasStringValue rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf powla:string ;
                     rdfs:domain powla:Terminal ;
                     rdfs:range xsd:string ;
                     owl:deprecated "true"^^xsd:boolean ;
                     owl:versionInfo "deprecated in favor of powla:string"@en .


###  http://purl.org/powla/powla.owl#layerID
powla:layerID rdf:type owl:DatatypeProperty ;
              rdfs:domain powla:Layer ;
              rdfs:range xsd:string .


###  http://purl.org/powla/powla.owl#start
powla:start rdf:type owl:DatatypeProperty ;
            rdfs:domain powla:Node ;
            rdfs:range xsd:int ;
            rdfs:comment """OPTIONAL datatype property for powla:Node
RECOMMENDED datatype property for powla:Terminal

powla:start allows to specify a numerical (integer) index. This may be an offset (as in NIF) or a structure-sensitive index (as in ANNIS). Interpretation is implementation-specific, but end >= start."""@en .


###  http://purl.org/powla/powla.owl#startPosition
powla:startPosition rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf powla:start ;
                    rdfs:domain powla:Terminal ;
                    rdfs:range xsd:int ;
                    owl:deprecated "true"^^xsd:boolean ;
                    owl:versionInfo "DEPRECATED in favor of powla:start"@en .


###  http://purl.org/powla/powla.owl#string
powla:string rdf:type owl:DatatypeProperty ;
             rdfs:domain powla:Node ;
             rdfs:range xsd:string ;
             rdfs:comment """RECOMMENDED datatype property for powla:Terminal
OPTIONAL datatype property for powla:Node
powla:string carries the string value of the tokens to which this annotation unit (node) applies. For empty strings, this must be left unspecified.
Corresponds to nif:anchor."""@en .


###  http://semanticscience.org/resource/SIO_000300
sio:SIO_000300 rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               dc:identifier "SIO_000300" ;
               dcterms:description "A relation between a informational entity and its actual value (numeric, date, text, etc)."@en ;
               sio:subset "core" ,
                          "nlp" ,
                          "relations" ,
                          "sadi"@en ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "has value"@en .


###  http://www.w3.org/2006/time#days
time:days rdf:type owl:DatatypeProperty ;
          rdfs:domain time:GeneralDurationDescription ;
          rdfs:range xsd:decimal ;
          rdfs:comment "Longitud de, o elemento de la longitud de, una extensión temporal expresada en días."@es ,
                       "length of, or element of the length of, a temporal extent expressed in days"@en ;
          rdfs:label "days duration"@en ,
                     "duración en días"@es ;
          skos:definition "Longitud de, o elemento de la longitud de, una extensión temporal expresada en días."@es ,
                          "length of, or element of the length of, a temporal extent expressed in days"@en .


###  http://www.w3.org/2006/time#hours
time:hours rdf:type owl:DatatypeProperty ;
           rdfs:domain time:GeneralDurationDescription ;
           rdfs:range xsd:decimal ;
           rdfs:comment "Longitud de, o elemento de la longitud de, una extensión temporal expresada en horas."@es ,
                        "length of, or element of the length of, a temporal extent expressed in hours"@en ;
           rdfs:label "duración en horas"@es ,
                      "hours duration"@en ;
           skos:definition "Longitud de, o elemento de la longitud de, una extensión temporal expresada en horas."@es ,
                           "length of, or element of the length of, a temporal extent expressed in hours"@en .


###  http://www.w3.org/2006/time#minutes
time:minutes rdf:type owl:DatatypeProperty ;
             rdfs:domain time:GeneralDurationDescription ;
             rdfs:range xsd:decimal ;
             rdfs:comment "Longitud de, o elemento de la longitud de, una extensión temporal expresada en minutos."@es ,
                          "length, or element of, a temporal extent expressed in minutes"@en ;
             rdfs:label "minutes"@en ,
                        "minutos"@es ;
             skos:definition "Longitud de, o elemento de la longitud de, una extensión temporal expresada en minutos."@es ,
                             "length, or element of, a temporal extent expressed in minutes"@en .


###  http://www.w3.org/2006/time#months
time:months rdf:type owl:DatatypeProperty ;
            rdfs:domain time:GeneralDurationDescription ;
            rdfs:range xsd:decimal ;
            rdfs:comment "Longitud de, o elemento de la longitud de, una extensión temporal expresada en meses."@es ,
                         "length of, or element of the length of, a temporal extent expressed in months"@en ;
            rdfs:label "duración en meses"@es ,
                       "months duration"@en ;
            skos:definition "Longitud de, o elemento de la longitud de, una extensión temporal expresada en meses."@es ,
                            "length of, or element of the length of, a temporal extent expressed in months"@en .


###  http://www.w3.org/2006/time#numericDuration
time:numericDuration rdf:type owl:DatatypeProperty ;
                     rdfs:domain time:Duration ;
                     rdfs:range xsd:decimal ;
                     rdfs:comment "Valor de una extensión temporal expresada como un número decimal escalado por una unidad de tiempo."@es ,
                                  "Value of a temporal extent expressed as a decimal number scaled by a temporal unit"@en ;
                     rdfs:label "Numeric value of temporal duration"@en ,
                                "valor numérico de duración temporal"@es ;
                     skos:definition "Valor de una extensión temporal expresada como un número decimal escalado por una unidad de tiempo."@es ,
                                     "Value of a temporal extent expressed as a decimal number scaled by a temporal unit"@en .


###  http://www.w3.org/2006/time#second
time:second rdf:type owl:DatatypeProperty ;
            rdfs:domain time:GeneralDateTimeDescription ;
            rdfs:range xsd:decimal ;
            rdfs:comment "Posición de segundo en un sistema calendario-reloj."@es ,
                         "Second position in a calendar-clock system."@en ;
            rdfs:label "second"@en ,
                       "segundo"@es .


###  http://www.w3.org/2006/time#seconds
time:seconds rdf:type owl:DatatypeProperty ;
             rdfs:domain time:GeneralDurationDescription ;
             rdfs:range xsd:decimal ;
             rdfs:comment "Longitud de, o elemento de la longitud de, una extensión temporal expresada en segundos."@es ,
                          "length of, or element of the length of, a temporal extent expressed in seconds"@en ;
             rdfs:label "duración en segundos"@es ,
                        "seconds duration"@en ;
             rdfs:seeAlso <http://www.bipm.org/en/publications/si-brochure/second.html> .


###  http://www.w3.org/2006/time#weeks
time:weeks rdf:type owl:DatatypeProperty ;
           rdfs:domain time:GeneralDurationDescription ;
           rdfs:range xsd:decimal ;
           rdfs:comment "Longitud de, o elemento de la longitud de, una extensión temporal expresada en semanas."@es ,
                        "length of, or element of the length of, a temporal extent expressed in weeks"@en ;
           rdfs:label "duración en semanas"@es ,
                      "weeks duration"@en .


###  http://www.w3.org/2006/time#years
time:years rdf:type owl:DatatypeProperty ;
           rdfs:domain time:GeneralDurationDescription ;
           rdfs:range xsd:decimal ;
           rdfs:comment "Longitud de, o elemento de la longitud de, una extensión temporal expresada en años."@es ,
                        "length of, or element of the length of, a temporal extent expressed in years"@en ;
           rdfs:label "duración en años"@es ,
                      "years duration"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.org/powla/powla.owl#Corpus
powla:Corpus rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( powla:Document
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty powla:hasSuperDocument ;
                                                          owl:maxCardinality "0"^^xsd:nonNegativeInteger
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf powla:Document ;
             rdfs:comment """OPTIONAL type
A Corpus is a Document without superDocument"""@en .


###  http://purl.org/powla/powla.owl#Document
powla:Document rdf:type owl:Class ;
               rdfs:subClassOf powla:POWLAElement ,
                               [ owl:intersectionOf ( powla:POWLAElement
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty powla:documentID ;
                                                        owl:cardinality "1"^^xsd:nonNegativeInteger
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
               owl:disjointWith powla:Layer ,
                                powla:Node ,
                                powla:Relation ;
               rdfs:comment """OPTIONAL type
A document is a(n annotated piece of) primary data as defined by the respective use case. A document can aggregate other documents (e.g., the Bible consists of several books), we thus extend the notion of document to collections of documents.

powla:Document is roughly corresponding to SALT Graph and PAULA anno sets."""@en .


###  http://purl.org/powla/powla.owl#DocumentLayer
powla:DocumentLayer rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( powla:Layer
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty powla:hasDocument ;
                                                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf powla:Layer ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty powla:hasDocument ;
                                      owl:someValuesFrom owl:Thing
                                    ] ;
                    rdfs:comment """OPTIONAL type
Layer within a document"""@en .


###  http://purl.org/powla/powla.owl#DominanceRelation
powla:DominanceRelation rdf:type owl:Class ;
                        rdfs:subClassOf powla:Relation ;
                        rdfs:comment """DEPRECATED object property
Dominance relations are labeled (reified) relations with coverage inheritance, i.e., the target node covers all terminals of the source node(s). Dominance relations are typical for phrase structure syntax.

This property, originally motivated from PAULA,  is deprecated in POWLA, as dominance relations are sufficiently described by powla:Relation and powla:hasParent."""@en ;
                        owl:deprecated "true"^^xsd:boolean ;
                        owl:versionInfo "dominance relations aren't actually necessary, a Relation is a DominanceRelation if it coincides with a hasChild property"@en .


###  http://purl.org/powla/powla.owl#Layer
powla:Layer rdf:type owl:Class ;
            owl:equivalentClass [ rdf:type owl:Class ;
                                  owl:unionOf ( powla:MarkableLayer
                                                powla:StructLayer
                                                powla:TokenLayer
                                              )
                                ] ;
            rdfs:subClassOf powla:POWLAElement ,
                            [ owl:intersectionOf ( powla:POWLAElement
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty powla:layerID ;
                                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
            owl:disjointWith powla:Node ,
                             powla:Relation ;
            rdfs:comment """OPTIONAL type
A layer describes a group of annotations, this may be either within a document or independently from a particular document"""@en .


###  http://purl.org/powla/powla.owl#MarkableLayer
powla:MarkableLayer rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( powla:Layer
                                                               [ rdf:type owl:Class ;
                                                                 owl:complementOf powla:StructLayer
                                                               ]
                                                               [ rdf:type owl:Class ;
                                                                 owl:complementOf powla:TokenLayer
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf powla:Layer ;
                    rdfs:comment """OPTIONAL type
Markable layers are visualized in a special way. with the current modelling, the status of a layer as a markable layer can be inferred and does not need to be asserted."""@en .


###  http://purl.org/powla/powla.owl#Node
powla:Node rdf:type owl:Class ;
           rdfs:subClassOf powla:POWLAElement ;
           owl:disjointWith powla:Relation ;
           rdfs:comment """RECOMMENDED type.
Nodes represent units of linguistic annotation (`markables'). Typical nodes have a defined extension or a position in the annotated data.

However, nodes may also be empty or not determined in their position if the annotated category can apply to nodes with a defined extension or position. An example for a non-positionable node with zero extension is the annotation of implicit semantic roles.

El Salvador is now the only Latin American country which still has troops in [Iraq]_LOC. Nicaragua, Honduras and the Dominican Republic have withdrawn their troops [0]_LOC.

In terms of frame semantics, withdrawing toops requires a location element, marked by [0]_LOC, but this is not realized in the local sentence. We can, however, infer its existence from a frame inventory (and in this case, also connect it with a string in the preceding text -- this is not always the case). However, it is impossible to define its actual string position in the second sentence.

Yet, the element marked by [0]_LOC is a valid powla:Node because if a phrase like \"from Iraq\" would have occurred in the sentence, it would have been annotated with the same linguistic features as the empty element.

Note that rdf:type powla:Node is recommended, but not obligatory, as this can be RDFS-inferred from (the obligatory) powla:next."""@en .


###  http://purl.org/powla/powla.owl#Nonterminal
powla:Nonterminal rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( powla:Node
                                                             [ rdf:type owl:Class ;
                                                               owl:complementOf powla:Terminal
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ,
                                      [ owl:intersectionOf ( powla:Node
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty powla:hasChild ;
                                                               owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf powla:Node ,
                                  sio:SIO_000006 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty powla:hasChild ;
                                    owl:someValuesFrom owl:Thing
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty sio:SIO_000253 ;
                                    owl:someValuesFrom <http://purl.org/twc/dido#Utterance>
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty sio:SIO_000291 ;
                                    owl:someValuesFrom <http://purl.org/twc/dido#Utterance>
                                  ] ;
                  owl:disjointWith powla:Terminal ;
                  rdfs:comment """OPTIONAL type
A powla:Node which is not a powla:Terminal (see there), RDFS-inferrable from powla:hasParent."""@en .


###  http://purl.org/powla/powla.owl#POWLAElement
powla:POWLAElement rdf:type owl:Class ;
                   owl:equivalentClass [ rdf:type owl:Class ;
                                         owl:unionOf ( powla:Document
                                                       powla:Layer
                                                       powla:Node
                                                       powla:Relation
                                                     )
                                       ] ;
                   rdfs:subClassOf sio:SIO_000000 ;
                   rdfs:comment "ABSTRACT type for POWLA data structures, not to be directly applied to data."@en .


###  http://purl.org/powla/powla.owl#PointingRelation
powla:PointingRelation rdf:type owl:Class ;
                       rdfs:subClassOf powla:Relation ;
                       rdfs:comment """DEPRECATED object relation
A pointing relation is a labeled (reified) relation without coverage inheritance, i.e., the (terminals covered by the) target nodes do not typically overlap with the (terminals covered by the) source nodes.

This property, motivated from PAULA, is deprecated in POWLA, as it is sufiiently described by a relation without accompanying powla:hasParent."""@en ;
                       owl:deprecated "true"^^xsd:boolean ;
                       owl:versionInfo "pointing relations aren't actually necessary, a relation is a pointing relation if it does not coincide with a hasChild property."@en .


###  http://purl.org/powla/powla.owl#Relation
powla:Relation rdf:type owl:Class ;
               rdfs:subClassOf powla:POWLAElement ;
               rdfs:comment """RECOMMENDED type
A relation represents a labelled edge that holds between two powla nodes. POWLA employs a reified representation, where source and target are linked with the relation via powla:hasSource and powla:hasTarget (resp., powla:isSourceOf and powla:isTargetOf)"""@en ;
               owl:versionInfo """corresponding to SALT Edge, POM Relation

Note: in SALT no edges between Terminals"""@en .


###  http://purl.org/powla/powla.owl#Root
powla:Root rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( powla:Node
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty powla:hasParent ;
                                                        owl:cardinality "0"^^xsd:nonNegativeInteger
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
           rdfs:subClassOf [ owl:intersectionOf ( powla:Node
                                                  [ rdf:type owl:Class ;
                                                    owl:unionOf ( powla:Nonterminal
                                                                  powla:Terminal
                                                                )
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
           rdfs:comment """OPTIONAL type
A root node is a powla:Node which is not a subject of a powla:hasParent property.
A number of properties that organize linguistic annotations into documents and corpora are based on the notion of root nodes as this limits the number of necessary links between data points and data sets. powla:Root can be RDFS-inferred from these or inferred from the absence of powla:hasParent under a closed world assumption."""@en .


###  http://purl.org/powla/powla.owl#StructLayer
powla:StructLayer rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( powla:Layer
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty powla:rootOfDocument ;
                                                               owl:someValuesFrom [ owl:intersectionOf ( powla:Nonterminal
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty powla:hasChild ;
                                                                                                           owl:someValuesFrom powla:Nonterminal
                                                                                                         ]
                                                                                                       ) ;
                                                                                    rdf:type owl:Class
                                                                                  ]
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf powla:DocumentLayer ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty powla:rootOfDocument ;
                                    owl:someValuesFrom [ owl:intersectionOf ( powla:Nonterminal
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty powla:hasChild ;
                                                                                owl:someValuesFrom powla:Nonterminal
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ]
                                  ] ;
                  owl:disjointWith powla:TokenLayer ;
                  rdfs:comment """OPTIONAL type
Struct layers are visualized as directed acyclic graphs (i.e., generalized trees). with the current modelling, the status of a layer as a struct layer can be inferred and does not need to be asserted."""@en .


###  http://purl.org/powla/powla.owl#Terminal
powla:Terminal rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( powla:Node
                                                          [ rdf:type owl:Class ;
                                                            owl:complementOf powla:Nonterminal
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ,
                                   [ owl:intersectionOf ( powla:Node
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty powla:hasChild ;
                                                            owl:cardinality "0"^^xsd:nonNegativeInteger
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf powla:Node ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty powla:endPosition ;
                                 owl:minCardinality "1"^^xsd:nonNegativeInteger
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty powla:startPosition ;
                                 owl:minCardinality "1"^^xsd:nonNegativeInteger
                               ] ;
               rdfs:comment """OPTIONAL type
A terminal is a node which does not have a child node (cf. hasParent/hasChild). Can be used as a basis for text anchoring.

Also corresponds to the single `base segmentation' in LAF, and the `(privileged) tokenization layer' in PAULA 1.0, which is used for calculating and querying token distance in corpus information systems.
Where non-minimal segments are needed as `(privileged) tokenization layer', we recommend to use external vocabularies, e.g., explicit nif:Word and nif:nextWord annotations.

Optional, as it can be inferred from powla:hasParent under a closed world assumption."""@en ;
               owl:versionInfo "roughly corresponding to SALT Terminal, PAULA 1.0 Token and PAULA 1.1 Terminal"@en .


###  http://purl.org/powla/powla.owl#TokenLayer
powla:TokenLayer rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( powla:Layer
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty powla:rootOfDocument ;
                                                              owl:allValuesFrom powla:Terminal
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf powla:Layer ;
                 rdfs:comment """OPTIONAL type
Token layers consist of annotations of terminal nodes, only. This class is necessary for visualization only, under the closed world assumption, however, it can be inferred and does not need to be asserted."""@en .


###  http://purl.org/twc/dido#Dialogue
<http://purl.org/twc/dido#Dialogue> rdf:type owl:Class ;
                                    rdfs:subClassOf sio:SIO_000006 ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty sio:SIO_000028 ;
                                                      owl:someValuesFrom <http://purl.org/twc/dido#Turn>
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty sio:SIO_000028 ;
                                                      owl:someValuesFrom <http://purl.org/twc/dido#Utterance>
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty sio:SIO_000132 ;
                                                      owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                      owl:onClass [ rdf:type owl:Class ;
                                                                    owl:unionOf ( sio:SIO_000097
                                                                                  sio:SIO_000485
                                                                                )
                                                                  ]
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty sio:SIO_000008 ;
                                                      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass time:ProperInterval
                                                    ] ;
                                    rdfs:label "dialogue" ;
                                    skos:definition "an interactive communication between two or more entities" .


###  http://purl.org/twc/dido#DialogueAct
<http://purl.org/twc/dido#DialogueAct> rdf:type owl:Class ;
                                       rdfs:subClassOf sio:SIO_000614 ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty sio:SIO_000011 ;
                                                         owl:someValuesFrom <http://purl.org/twc/dido#Utterance>
                                                       ] ;
                                       rdfs:label "dialogue act" .


###  http://purl.org/twc/dido#DialogueActAnnotation
<http://purl.org/twc/dido#DialogueActAnnotation> rdf:type owl:Class ;
                                                 rdfs:subClassOf powla:Terminal ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty sio:SIO_000332 ;
                                                                   owl:someValuesFrom <http://purl.org/twc/dido#DialogueAct>
                                                                 ] ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty sio:SIO_000291 ;
                                                                   owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                   owl:onClass <http://purl.org/twc/dido#Utterance>
                                                                 ] ;
                                                 rdfs:label "dialogue act annotation" .


###  http://purl.org/twc/dido#DialogueTranscript
<http://purl.org/twc/dido#DialogueTranscript> rdf:type owl:Class ;
                                              rdfs:subClassOf sio:SIO_000069 ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty sio:SIO_000095 ;
                                                                owl:someValuesFrom sio:SIO_000089
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty sio:SIO_000059 ;
                                                                owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                                owl:onClass <http://purl.org/twc/dido#UtteranceText>
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty sio:SIO_000332 ;
                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass <http://purl.org/twc/dido#Dialogue>
                                                              ] ;
                                              rdfs:label "dialogue transcript"@en ;
                                              skos:definition "A digital or physical information content entity that provides a structured textual record of a conversation" .


###  http://purl.org/twc/dido#Interlocutor
<http://purl.org/twc/dido#Interlocutor> rdf:type owl:Class ;
                                        rdfs:subClassOf sio:SIO_000016 ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty sio:SIO_000227 ;
                                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass [ rdf:type owl:Class ;
                                                                        owl:unionOf ( sio:SIO_000097
                                                                                      sio:SIO_000485
                                                                                    )
                                                                      ]
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty sio:SIO_000356 ;
                                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass <http://purl.org/twc/dido#Dialogue>
                                                        ] ;
                                        rdfs:label "interlocutor" ;
                                        skos:definition "One who takes part in a conversation or dialogue" .


###  http://purl.org/twc/dido#Turn
<http://purl.org/twc/dido#Turn> rdf:type owl:Class ;
                                rdfs:subClassOf sio:SIO_000006 ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty sio:SIO_000068 ;
                                                  owl:someValuesFrom <http://purl.org/twc/dido#Dialogue>
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty sio:SIO_000139 ;
                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                  owl:onClass [ rdf:type owl:Class ;
                                                                owl:unionOf ( sio:SIO_000097
                                                                              sio:SIO_000485
                                                                            )
                                                              ]
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty sio:SIO_000008 ;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                  owl:onClass time:Interval
                                                ] ;
                                rdfs:label "turn" ;
                                skos:definition "a unit of conversation in which a single interlocutor holds the floor, without interruption from another interlocutor or other external circumstance" .


###  http://purl.org/twc/dido#Utterance
<http://purl.org/twc/dido#Utterance> rdf:type owl:Class ;
                                     rdfs:subClassOf sio:SIO_000006 ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://purl.org/twc/dido#hasAddressee> ;
                                                       owl:someValuesFrom <http://purl.org/twc/dido#Interlocutor>
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty sio:SIO_000008 ;
                                                       owl:someValuesFrom <http://purl.org/twc/dido#DialogueAct>
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty sio:SIO_000068 ;
                                                       owl:someValuesFrom <http://purl.org/twc/dido#Dialogue>
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty sio:SIO_000229 ;
                                                       owl:someValuesFrom <http://purl.org/twc/dido#UtteranceText>
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty sio:SIO_000139 ;
                                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass [ rdf:type owl:Class ;
                                                                     owl:unionOf ( sio:SIO_000097
                                                                                   sio:SIO_000485
                                                                                 )
                                                                   ]
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty sio:SIO_000292 ;
                                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass <http://purl.org/twc/dido#DialogueActAnnotation>
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty sio:SIO_000008 ;
                                                       owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass time:Interval
                                                     ] ;
                                     rdfs:label "utterance" ;
                                     skos:definition "a single unit of speech in spoken language that serves some pragmatic function" .


###  http://purl.org/twc/dido#UtteranceText
<http://purl.org/twc/dido#UtteranceText> rdf:type owl:Class ;
                                         rdfs:subClassOf sio:SIO_000078 ,
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty sio:SIO_000300 ;
                                                           owl:someValuesFrom rdfs:Literal
                                                         ] ;
                                         rdfs:label "utterance text" ;
                                         skos:definition "a textual entity representing the output of an utterance" .


###  http://semanticscience.org/resource/SIO_000000
sio:SIO_000000 rdf:type owl:Class ;
               dc:identifier "SIO_000000" ;
               dcterms:description "Every thing is an entity."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "entity"@en .


###  http://semanticscience.org/resource/SIO_000004
sio:SIO_000004 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_000776 ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty sio:SIO_000008 ;
                                 owl:someValuesFrom sio:SIO_000279
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty sio:SIO_000053 ;
                                 owl:allValuesFrom [ rdf:type owl:Class ;
                                                     owl:unionOf ( sio:SIO_000004
                                                                   sio:SIO_000370
                                                                 )
                                                   ]
                               ] ;
               dc:identifier "SIO_000004" ;
               dcterms:description "A material entity is a physical entity that is spatially extended, exists as a whole at any point in time and has mass."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "material entity"@en .


###  http://semanticscience.org/resource/SIO_000005
sio:SIO_000005 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_000614 ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty sio:SIO_000218 ;
                                 owl:someValuesFrom sio:SIO_000000
                               ] ;
               owl:disjointWith sio:SIO_000340 ;
               dc:identifier "SIO_000005" ;
               dcterms:description "A quality is an attribute that is intrinsically associated with its bearer (or its parts), but whose presence/absence and observed/measured value may vary."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "quality"@en .


###  http://semanticscience.org/resource/SIO_000006
sio:SIO_000006 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_000000 ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty sio:SIO_000053 ;
                                 owl:allValuesFrom sio:SIO_000006
                               ] ;
               dc:identifier "SIO_000006" ;
               dcterms:description "A process is an entity that is identifiable only through the unfolding of time, has temporal parts, and unless otherwise specified/predicted, cannot be identified from any instant of time in which it exists."@en ;
               sio:subset "core" ,
                          "process+" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "process"@en .


###  http://semanticscience.org/resource/SIO_000014
sio:SIO_000014 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_000112 ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty sio:SIO_000008 ;
                                 owl:someValuesFrom sio:SIO_000638
                               ] ;
               dc:identifier "SIO_000014" ;
               dcterms:description "A disposition is the tendency of a capability to be exhibited under certain conditions or in response to a certain stimulus (trigger)."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "disposition"@en ;
               skos:example "solubility (to dissolve when put in fluid); fragility (disposition to break when dropped)"@en .


###  http://semanticscience.org/resource/SIO_000015
sio:SIO_000015 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_000776 ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty sio:SIO_000053 ;
                                 owl:allValuesFrom sio:SIO_000015
                               ] ;
               dc:identifier "SIO_000015" ;
               dcterms:description "information content entity is an object that requires some background knowledge or procedure to correctly interpret."@en ;
               sio:subset "core" ,
                          "ice+" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "information content entity"@en .


###  http://semanticscience.org/resource/SIO_000016
sio:SIO_000016 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_000340 ;
               dc:identifier "SIO_000016" ;
               dcterms:description "A role is a realizable entity that describes behaviours, rights and obligations of an entity in some particular circumstance."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "role"@en .


###  http://semanticscience.org/resource/SIO_000017
sio:SIO_000017 rdf:type owl:Class ;
               rdfs:subClassOf sio:SIO_000112 ;
               dc:identifier "SIO_000017" ;
               dcterms:description "A function is a capability that satisfies some agentive objective, or (evolutionary) optimization."@en ;
               sio:subset "core" ;
               rdfs:isDefinedBy <http://semanticscience.org/ontology/sio.owl> ;
               rdfs:label "function"@en .


