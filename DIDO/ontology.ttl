###  http://purl.org/twc/dido#Dialogue
<http://purl.org/twc/dido#Dialogue> rdf:type owl:Class ;
                                    rdfs:subClassOf <http://semanticscience.org/resource/SIO_000006> ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <http://semanticscience.org/resource/SIO_000028> ;
                                                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass <http://purl.org/twc/dido#Utterance>
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <http://semanticscience.org/resource/SIO_000132> ;
                                                      owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                      owl:onClass [ rdf:type owl:Class ;
                                                                    owl:unionOf ( <http://semanticscience.org/resource/SIO_000097>
                                                                                  <http://semanticscience.org/resource/SIO_000485>
                                                                                )
                                                                  ]
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <http://semanticscience.org/resource/SIO_000008> ;
                                                      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass <http://www.w3.org/2006/time#ProperInterval>
                                                    ] ;
                                    rdfs:label "dialogue" ;
                                    <http://www.w3.org/2004/02/skos/core#definition> "an interactive communication between two or more entities" .


###  http://purl.org/twc/dido#DialogueTranscript
<http://purl.org/twc/dido#DialogueTranscript> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://semanticscience.org/resource/SIO_000069> ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://semanticscience.org/resource/SIO_000095> ;
                                                                owl:someValuesFrom <http://semanticscience.org/resource/SIO_000089>
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://semanticscience.org/resource/SIO_000059> ;
                                                                owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                                owl:onClass <http://purl.org/twc/dido#UtteranceText>
                                                              ] ,
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://semanticscience.org/resource/SIO_000332> ;
                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass <http://purl.org/twc/dido#Dialogue>
                                                              ] ;
                                              rdfs:label "dialogue transcript"@en ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "A digital or physical information content entity that provides a structured textual record of a conversation" .


###  http://purl.org/twc/dido#Interlocutor
<http://purl.org/twc/dido#Interlocutor> rdf:type owl:Class ;
                                        rdfs:subClassOf <http://semanticscience.org/resource/SIO_000016> ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://semanticscience.org/resource/SIO_000227> ;
                                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass [ rdf:type owl:Class ;
                                                                        owl:unionOf ( <http://semanticscience.org/resource/SIO_000097>
                                                                                      <http://semanticscience.org/resource/SIO_000485>
                                                                                    )
                                                                      ]
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://semanticscience.org/resource/SIO_000356> ;
                                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass <http://purl.org/twc/dido#Dialogue>
                                                        ] ;
                                        rdfs:label "interlocutor" ;
                                        <http://www.w3.org/2004/02/skos/core#definition> "One who takes part in a conversation or dialogue" .


###  http://purl.org/twc/dido#Utterance
<http://purl.org/twc/dido#Utterance> rdf:type owl:Class ;
                                     rdfs:subClassOf <http://semanticscience.org/resource/SIO_000006> ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://semanticscience.org/resource/SIO_000229> ;
                                                       owl:someValuesFrom <http://purl.org/twc/dido#UtteranceText>
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://semanticscience.org/resource/SIO_000068> ;
                                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass <http://purl.org/twc/dido#Dialogue>
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://semanticscience.org/resource/SIO_000139> ;
                                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass [ rdf:type owl:Class ;
                                                                     owl:unionOf ( <http://semanticscience.org/resource/SIO_000097>
                                                                                   <http://semanticscience.org/resource/SIO_000485>
                                                                                 )
                                                                   ]
                                                     ] ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty <http://semanticscience.org/resource/SIO_000008> ;
                                                       owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                       owl:onClass <http://www.w3.org/2006/time#Interval>
                                                     ] ;
                                     rdfs:label "utterance" ;
                                     <http://www.w3.org/2004/02/skos/core#definition> "a single unit of speech in spoken language that serves some pragmatic function" .


###  http://purl.org/twc/dido#UtteranceText
<http://purl.org/twc/dido#UtteranceText> rdf:type owl:Class ;
                                         rdfs:subClassOf <http://semanticscience.org/resource/SIO_000078> ,
