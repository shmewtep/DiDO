<http://purl.org/twc/dido/individuals#dataset/daic-woz> a sio:SIO_000089,
        dcat:Dataset .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_0> a dido:UtteranceText ;
    sio:SIO_000300 "hi i'm ellie thanks for coming in today i was created to talk to people in a safe and secure environment"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_1> a dido:UtteranceText ;
    sio:SIO_000300 "thank you"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_10> a dido:UtteranceText ;
    sio:SIO_000300 "really me too"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_100> a dido:UtteranceText ;
    sio:SIO_000300 "you know just like hey instead of instead of doing this how about doing that or hey you're good at this why aren't you doing that or something like that just you know i'm always looking for new opportunities so they always point out things that maybe i might i could do differently"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_101> a dido:UtteranceText ;
    sio:SIO_000300 "instead of just being negative saying hey don't do that that's no that's why are you doing that it's a waste of time"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_102> a dido:UtteranceText ;
    sio:SIO_000300 "mmm"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_103> a dido:UtteranceText ;
    sio:SIO_000300 "that's good"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_104> a dido:UtteranceText ;
    sio:SIO_000300 "how are you at controlling your temper"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_105> a dido:UtteranceText ;
    sio:SIO_000300 "um i guess it depends on who you talk to"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_106> a dido:UtteranceText ;
    sio:SIO_000300 "<laughter>"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_107> a dido:UtteranceText ;
    sio:SIO_000300 "i'm i'm okay at it i could probably work at that"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_108> a dido:UtteranceText ;
    sio:SIO_000300 "um"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_109> a dido:UtteranceText ;
    sio:SIO_000300 "i don't know i mean i can i i think i can do better at it"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_11> a dido:UtteranceText ;
    sio:SIO_000300 "oh great"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_110> a dido:UtteranceText ;
    sio:SIO_000300 "can you give me an example of that"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_111> a dido:UtteranceText ;
    sio:SIO_000300 "well back to the point about people provoking me so i mean i try not to blow steam and let them get under my skin so i just usually try not to let it get to me"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_112> a dido:UtteranceText ;
    sio:SIO_000300 "but i don't know i guess with temper i guess it depends on how i handle my stress"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_113> a dido:UtteranceText ;
    sio:SIO_000300 "lately i've been better at it just because i think my situation's been a little bit better"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_114> a dido:UtteranceText ;
    sio:SIO_000300 "that's good"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_115> a dido:UtteranceText ;
    sio:SIO_000300 "have you been diagnosed with depression"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_116> a dido:UtteranceText ;
    sio:SIO_000300 "no"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_117> a dido:UtteranceText ;
    sio:SIO_000300 "have you ever been diagnosed with p_t_s_d"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_118> a dido:UtteranceText ;
    sio:SIO_000300 "no"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_119> a dido:UtteranceText ;
    sio:SIO_000300 "have you ever served in the military"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_12> a dido:UtteranceText ;
    sio:SIO_000300 "where do you live"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_120> a dido:UtteranceText ;
    sio:SIO_000300 "no"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_121> a dido:UtteranceText ;
    sio:SIO_000300 "okay"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_122> a dido:UtteranceText ;
    sio:SIO_000300 "is there anything you regret"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_123> a dido:UtteranceText ;
    sio:SIO_000300 "um"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_124> a dido:UtteranceText ;
    sio:SIO_000300 "nothing major"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_125> a dido:UtteranceText ;
    sio:SIO_000300 "i mean maybe when i was younger i could've traveled more or i could've worked towards something that paid better job-wise but i mean"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_126> a dido:UtteranceText ;
    sio:SIO_000300 "those are all things that i think at any point in life you always think like well i coulda shoulda would've done but you know"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_127> a dido:UtteranceText ;
    sio:SIO_000300 "but then again i think that's natural for anybody i mean i could i could've become a banker or i could've become a lawyer or a doctor and made about ten times the money that i make now but"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_128> a dido:UtteranceText ;
    sio:SIO_000300 "but then again i don't like the law and i don't like medicine so so i'm it wasn't meant to be so"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_129> a dido:UtteranceText ;
    sio:SIO_000300 "right"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_13> a dido:UtteranceText ;
    sio:SIO_000300 "i live in west los angeles the west side"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_130> a dido:UtteranceText ;
    sio:SIO_000300 "there are always trade offs in life aren't there"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_131> a dido:UtteranceText ;
    sio:SIO_000300 "yeah"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_132> a dido:UtteranceText ;
    sio:SIO_000300 "what made you decide to do that"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_133> a dido:UtteranceText ;
    sio:SIO_000300 "so"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_134> a dido:UtteranceText ;
    sio:SIO_000300 "um i think"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_135> a dido:UtteranceText ;
    sio:SIO_000300 "i think my"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_136> a dido:UtteranceText ;
    sio:SIO_000300 "in my life i knew that"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_137> a dido:UtteranceText ;
    sio:SIO_000300 "i there's a lot of things i have <ha> there's more dislikes <laughter> than likes so i kinda narrowed it down to what am i good at and what am i not good at and what am i gonna work well or who who am i gonna work well with and who will i not work well with"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_138> a dido:UtteranceText ;
    sio:SIO_000300 "so i kind of i kinda sorted out and then the list kind of"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_139> a dido:UtteranceText ;
    sio:SIO_000300 "mmm kind of answered itself so"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_14> a dido:UtteranceText ;
    sio:SIO_000300 "nice"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_140> a dido:UtteranceText ;
    sio:SIO_000300 "that sounds really hard"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_141> a dido:UtteranceText ;
    sio:SIO_000300 "no it i don't think it was hard but it was just but i think it was a real reality check and i think it it's kind of a good thing 'cause sometimes trying to conform to doing things that doesn't really fit you doesn't make sense"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_142> a dido:UtteranceText ;
    sio:SIO_000300 "it's like trying to shove a a round peg into a square a square hole and it's like it just no matter how you try to shove it in it's not gonna go in so sometimes it's just might as well go down a path that seems to work better for you"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_143> a dido:UtteranceText ;
    sio:SIO_000300 "right"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_144> a dido:UtteranceText ;
    sio:SIO_000300 "that makes sense"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_145> a dido:UtteranceText ;
    sio:SIO_000300 "what's one of your most memorable experiences"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_146> a dido:UtteranceText ;
    sio:SIO_000300 "memorable experiences um hmm"^^xsd:string .

<http://purl.org/twc/dido/individuals#utteranceTexts/None_147> a dido:UtteranceText ;
