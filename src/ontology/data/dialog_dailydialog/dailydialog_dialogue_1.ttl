ex:utteranceText_dd_1_0 a dido:UtteranceText ;
    sio:SIO_000300 "Can you do push-ups ?"^^xsd:string .

ex:utteranceText_dd_1_1 a dido:UtteranceText ;
    sio:SIO_000300 "Of course I can . It's a piece of cake ! Believe it or not , I can do 30 push-ups a minute ."^^xsd:string .

ex:utteranceText_dd_1_2 a dido:UtteranceText ;
    sio:SIO_000300 "Really ? I think that's impossible !"^^xsd:string .

ex:utteranceText_dd_1_3 a dido:UtteranceText ;
    sio:SIO_000300 "You mean 30 push-ups ?"^^xsd:string .

ex:utteranceText_dd_1_4 a dido:UtteranceText ;
    sio:SIO_000300 "Yeah !"^^xsd:string .

ex:utteranceText_dd_1_5 a dido:UtteranceText ;
    sio:SIO_000300 "It's easy . If you do exercise everyday , you can make it , too ."^^xsd:string .

