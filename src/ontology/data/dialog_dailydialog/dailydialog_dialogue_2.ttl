    dcterms:isReferencedBy <https://arxiv.org/abs/1710.03957> ;
    dcat:landingPage <https://huggingface.co/datasets/daily_dialog> .

ex:utteranceText_dd_2_0 a dido:UtteranceText ;
    sio:SIO_000300 "Can you study with the radio on ?"^^xsd:string .

ex:utteranceText_dd_2_1 a dido:UtteranceText ;
    sio:SIO_000300 "No , I listen to background music ."^^xsd:string .

ex:utteranceText_dd_2_2 a dido:UtteranceText ;
    sio:SIO_000300 "What is the difference ?"^^xsd:string .

ex:utteranceText_dd_2_3 a dido:UtteranceText ;
    sio:SIO_000300 "The radio has too many comerials ."^^xsd:string .

ex:utteranceText_dd_2_4 a dido:UtteranceText ;
    sio:SIO_000300 "That's true , but then you have to buy a record player ."^^xsd:string .

