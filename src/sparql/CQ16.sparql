PREFIX dido: <http://purl.org/twc/dido#>
PREFIX sio: <http://semanticscience.org/resource/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

# CQ16: What utterances did inteerlocutor make regarding entity?
SELECT DISTINCT ?utterance ?text
WHERE {
  # Link Interlocutor to Utterance
  ?utterance sio:SIO_000063 ?interlocutor . # isAgentIn
  
  # Link Utterance to the Assertion
  ?utterance dido:supports ?assertion .
  
  # Use Reification to find the entity within the triple
  ?assertion rdf:reifies << ?s ?p ?o >> .
  
  # Fetch text for the utterance
  ?utterance sio:SIO_000229 ?utteranceText . # hasOutput
  ?utteranceText sio:hasText ?text .

  # Filter: The entity must be the subject or the object of the claim
  FILTER(?s = :targetEntity || ?o = :targetEntity)
}